{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@db/*": ["../../lib/db/*"]
    }
  },
  "include": ["src/**/*.ts", "../../lib/db/**/*.ts"],
  "exclude": ["node_modules"]
}
