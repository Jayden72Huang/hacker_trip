page {
  --bg: #F4F1E8;
  --surface: #FFFFFF;
  --sunken: #ECE8DB;
  --ink: #000000;
  --text: #000000;
  --sub: #3D3D3D;
  --mut: #7A7A75;
  --blue: #0C51ED;
  --blue-pressed: #0A41BE;
  --yellow: #FBD902;
  --success: #13B36B;
  --urgent: #FF4D2E;

  --td-brand-color: #0C51ED;
  --td-brand-color-active: #0A41BE;
  --td-brand-color-hover: #2E6AF0;
  --td-warning-color: #FBD902;
  --td-success-color: #13B36B;
  --td-error-color: #FF4D2E;
  --td-bg-color-page: #F4F1E8;
  --td-bg-color-container: #FFFFFF;
  --td-text-color-primary: #000000;
  --td-text-color-secondary: #3D3D3D;
  --td-text-color-placeholder: #7A7A75;
  --td-component-stroke: #000000;
  --td-radius-default: 8px;

  background-color: #F4F1E8;
  color: #000000;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  overflow-x: hidden;
}

view,
text,
scroll-view,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 0;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 0 32rpx 140rpx;
  background: #F4F1E8;
}

.page--tab {
  /* 顶部 tab 条占位：状态栏和标题栏由 sticky navbar 撑开，这里只补 tab 条高度 */
  padding-top: 150rpx;
}

.content {
  padding-top: 24rpx;
}

.page-title {
  margin: 24rpx 0 16rpx;
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 900;
  letter-spacing: 0;
  color: #000000;
}

.page-subtitle {
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.brutal-card,
.glass,
.card {
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.brutal-card,
.card {
  padding: 32rpx;
}

.glass-strong {
  background: #FFFFFF;
  border: 5rpx solid #000000;
  box-shadow: 12rpx 12rpx 0 0 #000000;
}

.brutal-panel {
  padding: 32rpx;
  margin-bottom: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.ai-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  margin: 12rpx 0 24rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 24rpx;
  font-weight: 800;
}

.placeholder {
  padding: 32rpx;
  color: #3D3D3D;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.placeholder-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #000000;
}

.placeholder-copy {
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 8rpx 18rpx;
  margin: 0 12rpx 12rpx 0;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
}

.chip-accent {
  background: #FBD902;
  color: #000000;
}

.btn-primary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  padding: 0 28rpx;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 28rpx;
  font-weight: 900;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.btn-primary {
  color: #FFFFFF;
  background: #0C51ED;
}

.btn-ghost {
  color: #000000;
  background: #FFFFFF;
}

.btn-primary:active,
.btn-ghost:active,
.tap:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.section-title {
  margin: 36rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #000000;
}

.muted {
  color: #7A7A75;
}

.accent-text,
.gradient-text {
  color: #0C51ED;
}

.divider {
  height: 2rpx;
  margin: 32rpx 0;
  background: #000000;
}

.aurora {
  display: none;
}

/* ---------------- 骨架屏 / 空态（全局复用） ---------------- */
.skeleton {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* 灰块骨架卡片，套用野兽派纯黑边 + 硬投影 */
.skeleton-card {
  padding: 26rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.skeleton-line {
  height: 28rpx;
  background: #ECE8DB;
  border-radius: 8rpx;
}

.skeleton-line + .skeleton-line {
  margin-top: 18rpx;
}

.skeleton-line--title {
  height: 38rpx;
  width: 60%;
}

.skeleton-line--short {
  width: 40%;
}

.skeleton-line--mid {
  width: 75%;
}

.skeleton-hint {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7A7A75;
  text-align: center;
}

/* 通用空态（与 schedule 的 .my-events-empty 同款野兽派虚线框） */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 56rpx 24rpx;
  background: #FFFFFF;
  border: 4rpx dashed #000000;
  border-radius: 16rpx;
}

.empty-state-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
  text-align: center;
}

.empty-state-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #5A5A55;
  text-align: center;
  line-height: 1.5;
}

/* 空态 CTA（野兽派黄底硬投影），与 schedule 的 .empty-cta 同款 */
.empty-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  margin-top: 6rpx;
  padding: 0 32rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.empty-cta--active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}
