/**
 * HackerTrip 小程序全局样式 —— Claude 暖调（奶油纸感 + 黏土橙）
 * 设计规范见 style.md / design.md。浅色为主，低对比、极简留白、无炫光。
 * 单位 rpx（750 = 屏宽）。8rpx 栅格。
 */
page {
  --bg: #faf9f5;
  --card: #ffffff;
  --panel: #f4f2ec;
  --ink: #1f1e1d;
  --sub: #6b6862;
  --mut: #94918a;
  --clay: #c96442;
  --clay-dk: #9c4f30;
  --border: #ece9e0;
  --chip-bg: #f4ede4;
  --chip-fg: #9c6a3f;
  --ok: #3f9c6a;
  --gold: #c96442;

  background-color: #faf9f5;
  color: #1f1e1d;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, Arial,
    sans-serif;
  font-size: 28rpx;
  line-height: 1.65;
}

view,
text,
scroll-view,
button,
input {
  box-sizing: border-box;
}

/* ---------- 容器 ---------- */
.page {
  padding: 24rpx 40rpx 72rpx;
}

/* ---------- 卡片 ---------- */
.glass,
.card {
  background: #ffffff;
  border: 1rpx solid #ece9e0;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(60, 50, 40, 0.06);
}
.card {
  padding: 36rpx;
}
.glass-strong {
  background: #ffffff;
  border: 1rpx solid #e6e3da;
}
.glow {
  box-shadow: 0 16rpx 40rpx rgba(201, 100, 66, 0.18);
}

/* 按压反馈 */
.tap {
  transition: transform 0.12s ease, opacity 0.12s ease;
}
.tap:active {
  transform: scale(0.97);
  opacity: 0.92;
}

.muted {
  color: #94918a;
}
.accent-text {
  color: #c96442;
}
.gradient-text {
  color: #c96442;
}

/* ---------- chip ---------- */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 9rpx 22rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  line-height: 1.3;
  background: #f4ede4;
  border: 1rpx solid #efe6da;
  color: #9c6a3f;
  margin: 0 12rpx 12rpx 0;
}
.chip-accent {
  background: #c96442;
  border-color: #c96442;
  color: #fff;
}

/* ---------- 按钮 ---------- */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: #c96442;
  box-shadow: 0 12rpx 32rpx rgba(201, 100, 66, 0.28);
  border: none;
  transition: transform 0.12s ease;
}
.btn-primary:active {
  transform: scale(0.98);
}
.btn-primary::after {
  border: none;
}
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  color: #1f1e1d;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
  transition: transform 0.12s ease;
}
.btn-ghost:active {
  transform: scale(0.98);
}
.btn-ghost::after {
  border: none;
}

/* ---------- 标题 / 分隔 ---------- */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.divider {
  height: 1rpx;
  background: #ece9e0;
  margin: 32rpx 0;
}
.serif {
  font-family: "Songti SC", "Tiempos Text", Georgia, serif;
}

/* 旧的暗色光晕在浅色主题下不再需要，置空避免残留 */
.aurora {
  display: none;
}

.fade-up {
  animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
