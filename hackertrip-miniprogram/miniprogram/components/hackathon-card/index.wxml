<view class="hcard" data-id="{{item.id}}" bindtap="onCardTap">
  <view class="hcard-top">
    <view class="hcard-title">{{item.name}}</view>
    <button class="bookmark {{bookmarked ? 'active' : ''}}" catchtap="onBookmark" aria-label="订阅赛事">
      <text>{{bookmarked ? '已订阅' : '订阅'}}</text>
      <text class="bookmark-count">{{item.bookmarkCountText || '0'}}</text>
    </button>
  </view>

  <view class="hcard-info">
    <view class="info-row">
      <text class="info-label">时间</text>
      <text class="info-value">{{item.dateText || '待确认'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">城市</text>
      <text class="info-value">{{item.cityText || item.city || '待确认'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">地点</text>
      <text class="info-value">{{item.locationText || item.location || '待确认'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">模式</text>
      <text class="mode-pill">{{item.modeText || '待确认'}}</text>
    </view>
  </view>

  <view wx:if="{{item.summary}}" class="hcard-summary">{{item.summary}}</view>

  <view wx:if="{{item.theme || item.tracks}}" class="hcard-tags">
    <text wx:if="{{item.theme}}" class="topic-tag topic-tag--theme">{{item.theme}}</text>
    <text wx:for="{{item.tracks}}" wx:key="*this" wx:if="{{index < 3}}" class="topic-tag">{{item}}</text>
  </view>

  <view class="hcard-foot">
    <view class="metric-block metric-block--prize">
      <text class="metric-label">奖金</text>
      <text class="metric-value">{{item.prizeText || '待确认'}}</text>
    </view>
    <view class="metric-block metric-block--heat">
      <text class="metric-label">热度</text>
      <text class="metric-value">{{item.heatText || '0'}}</text>
    </view>
    <text class="status-tag {{item.status}}">{{statusText[item.status] || item.status}}</text>
  </view>

  <view class="hcard-actions">
    <button class="hcard-link" catchtap="onCardTap" hover-class="hcard-link--active">
      查看详情
    </button>
    <button wx:if="{{item.canRegister}}" class="hcard-register" catchtap="onRegister" hover-class="hcard-register--active">
      立即报名
    </button>
  </view>
</view>
