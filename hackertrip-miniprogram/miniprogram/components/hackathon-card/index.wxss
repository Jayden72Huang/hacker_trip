.hcard {
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.hcard:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.hcard-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hcard-title {
  flex: 1;
  margin-right: 18rpx;
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
  letter-spacing: 0;
}

.bookmark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 58rpx !important;
  height: 58rpx;
  padding: 0;
  margin: 0;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  line-height: 1;
}

/* 去掉微信 button 默认的 ::after 边框，避免双重边框 */
.bookmark::after {
  border: none;
}

.bookmark.active {
  background: #FBD902;
}

.hcard-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-item {
  padding: 8rpx 12rpx;
  color: #000000;
  background: #ECE8DB;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.meta-item.mode {
  color: #FFFFFF;
  background: #000000;
}

.hcard-summary {
  display: -webkit-box;
  margin-top: 18rpx;
  overflow: hidden;
  color: #3D3D3D;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.hcard-tracks {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.hcard-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #000000;
}

.prize {
  min-width: 0;
  color: #000000;
  font-size: 25rpx;
  font-weight: 900;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border: 2rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.status-tag.ongoing {
  color: #000000;
  background: #3DDC84;
}

.status-tag.upcoming {
  color: #000000;
  background: #FBD902;
}

.status-tag.ended {
  color: #FFFFFF;
  background: #000000;
}

.hcard-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.hcard-link,
.hcard-register {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.hcard-link {
  flex: 1;
  color: #FFFFFF;
  background: #0C51ED;
  box-shadow: 5rpx 5rpx 0 0 #000000;
}

.hcard-link--active,
.hcard-register--active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.hcard-register {
  width: 132rpx;
  color: #000000;
  background: #FBD902;
  box-shadow: 5rpx 5rpx 0 0 #000000;
}
