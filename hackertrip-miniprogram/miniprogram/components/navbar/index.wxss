.navbar {
  position: sticky;
  top: 0;
  /* 高于 canvas 同层渲染与底部操作栏，避免被原生 canvas 盖住 */
  z-index: 500;
  width: 100%;
  background: #F4F1E8;
}

.navbar__row {
  display: flex;
  align-items: center;
  height: 44px;
  padding-left: 24rpx;
}

.navbar__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 96rpx;
}

.navbar__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.navbar__button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.navbar__title {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  overflow: hidden;
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 44px;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.navbar__capsule-safe {
  flex: 0 0 auto;
  height: 44px;
}

/* CSS 图标（替代 tdesign，省 5.4M 包体） */
.icon-chevron-left {
  width: 18rpx; height: 18rpx;
  border-left: 5rpx solid #000000;
  border-bottom: 5rpx solid #000000;
  transform: rotate(45deg);
  margin-left: 8rpx;
}
.icon-home { display: flex; flex-direction: column; align-items: center; }
.icon-home__roof {
  width: 0; height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-bottom: 14rpx solid #000000;
}
.icon-home__body {
  width: 18rpx; height: 13rpx;
  border: 4rpx solid #000000;
  border-top: none;
}
