<view class="focus-page admin-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view class="focus-title">审核工作台</view>
    <view class="focus-subtitle">仅管理员可访问，用于组织者审核、赛事审核和正式赛事上下线。</view>

    <view wx:if="{{loading}}" class="brutal-box">
      <view class="box-title">加载中</view>
      <view class="box-copy">正在读取赛事审核队列。</view>
    </view>

    <view wx:elif="{{!isAdmin}}" class="brutal-box">
      <view class="box-title">无管理权限</view>
      <view class="box-copy">{{error || '当前账号不是管理员。'}}</view>
    </view>

    <block wx:else>
      <view class="admin-tabs admin-tabs--four">
        <button class="admin-tab {{activeTab === 'drafts' ? 'admin-tab--active' : ''}}" data-tab="drafts" bindtap="switchTab">赛事审核 {{drafts.length}}</button>
        <button class="admin-tab {{activeTab === 'claims' ? 'admin-tab--active' : ''}}" data-tab="claims" bindtap="switchTab">赛事认领 {{claims.length}}</button>
        <button class="admin-tab {{activeTab === 'organizers' ? 'admin-tab--active' : ''}}" data-tab="organizers" bindtap="switchTab">组织者审核 {{organizers.length}}</button>
        <button class="admin-tab {{activeTab === 'live' ? 'admin-tab--active' : ''}}" data-tab="live" bindtap="switchTab">正式赛事 {{hackathons.length}}</button>
      </view>

      <view wx:if="{{activeTab === 'drafts'}}">
        <view wx:if="{{drafts.length === 0}}" class="brutal-box">
          <view class="box-title">暂无待审核赛事</view>
          <view class="box-copy">组织者提交的新赛事会出现在这里。</view>
        </view>
        <view wx:for="{{drafts}}" wx:key="_id" class="admin-card" bindtap="goDetail" data-id="{{item.id || item.hackathonId}}">
          <view class="admin-card-head">
            <view>
              <view class="admin-title">{{item.name}}</view>
              <view class="admin-meta">{{item.city}} · {{item.startDate}} - {{item.endDate}}</view>
            </view>
            <text class="status-pill">{{item.statusText}}</text>
          </view>
          <view class="admin-copy">{{item.summary || '暂无简介'}}</view>
          <view class="admin-row">
            <text class="admin-label">模式</text>
            <text>{{item.mode}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">奖金</text>
            <text class="{{item.prizePool ? '' : 'field-missing'}}">{{item.prizePool || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">赛道</text>
            <text class="{{item.tracksText ? '' : 'field-missing'}}">{{item.tracksText || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">主办方</text>
            <text class="{{item.organizerName ? '' : 'field-missing'}}">{{item.organizerName || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">链接</text>
            <text class="{{item.website ? '' : 'field-missing'}}">{{item.website || '未填写'}}</text>
          </view>
          <view class="admin-actions">
            <button class="small-btn small-btn--blue" data-id="{{item._id}}" catchtap="approveDraft">发布</button>
            <button class="small-btn small-btn--white" data-id="{{item._id}}" data-type="draft" catchtap="openReject">拒绝</button>
          </view>
        </view>
      </view>

      <view wx:elif="{{activeTab === 'claims'}}">
        <view wx:if="{{claims.length === 0}}" class="brutal-box">
          <view class="box-title">暂无待审核认领</view>
          <view class="box-copy">通过组织者认证后，主办方提交的赛事归属申请会出现在这里。</view>
        </view>
        <view wx:for="{{claims}}" wx:key="_id" class="admin-card" bindtap="goDetail" data-id="{{item.eventId}}">
          <view class="admin-card-head">
            <view>
              <view class="admin-title">{{item.eventName}}</view>
              <view class="admin-meta">{{item.eventCity || '城市未填'}} · {{item.eventDateText}}</view>
            </view>
            <text class="status-pill">{{item.statusText}}</text>
          </view>
          <view class="admin-copy">{{item.note || '暂无认领说明'}}</view>
          <view class="admin-row">
            <text class="admin-label">申请方</text>
            <text>{{item.organizerName || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">身份</text>
            <text class="{{item.claimRole ? '' : 'field-missing'}}">{{item.claimRole || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">联系</text>
            <text class="{{item.contact ? '' : 'field-missing'}}">{{item.contact || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">证明</text>
            <text class="{{item.proofUrl ? '' : 'field-missing'}}">{{item.proofUrl || '未填写'}}</text>
          </view>
          <view class="admin-actions">
            <button class="small-btn small-btn--blue" data-id="{{item._id}}" catchtap="approveClaim">通过认领</button>
            <button class="small-btn small-btn--white" data-id="{{item._id}}" data-type="claim" catchtap="openReject">拒绝</button>
          </view>
        </view>
      </view>

      <view wx:elif="{{activeTab === 'organizers'}}">
        <view wx:if="{{organizers.length === 0}}" class="brutal-box">
          <view class="box-title">暂无待审核组织者</view>
          <view class="box-copy">用户提交的组织者认证申请会出现在这里。</view>
        </view>
        <view wx:for="{{organizers}}" wx:key="_id" class="admin-card">
          <view class="admin-card-head">
            <view>
              <view class="admin-title">{{item.orgName}}</view>
              <view class="admin-meta">{{item.role}} · {{item.contact}}</view>
            </view>
            <text class="status-pill">{{item.statusText}}</text>
          </view>
          <view class="admin-copy">{{item.note || '暂无补充说明'}}</view>
          <view class="admin-row">
            <text class="admin-label">官网</text>
            <text>{{item.website || '未填写'}}</text>
          </view>
          <view class="admin-actions">
            <button class="small-btn small-btn--blue" data-id="{{item._id}}" bindtap="approveOrganizer">通过</button>
            <button class="small-btn small-btn--white" data-id="{{item._id}}" data-type="organizer" bindtap="openReject">拒绝</button>
          </view>
        </view>
      </view>

      <view wx:else>
        <view wx:if="{{hackathons.length === 0}}" class="brutal-box">
          <view class="box-title">暂无正式赛事</view>
          <view class="box-copy">审核发布后的赛事会出现在这里。</view>
        </view>
        <view wx:for="{{hackathons}}" wx:key="_id" class="admin-card" bindtap="goDetail" data-id="{{item.id}}">
          <view class="admin-card-head">
            <view>
              <view class="admin-title">{{item.name}}</view>
              <view class="admin-meta">{{item.city}} · {{item.startDate}} - {{item.endDate}}</view>
            </view>
            <text class="status-pill {{item.isPublished === false ? 'status-pill--off' : ''}}">{{item.publishedText}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">模式</text>
            <text>{{item.modeText}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">奖金</text>
            <text class="{{item.prizePool ? '' : 'field-missing'}}">{{item.prizePool || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">赛道</text>
            <text class="{{item.tracksText ? '' : 'field-missing'}}">{{item.tracksText || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">主办方</text>
            <text class="{{item.organizerName ? '' : 'field-missing'}}">{{item.organizerName || '未填写'}}</text>
          </view>
          <view class="admin-row">
            <text class="admin-label">链接</text>
            <text class="{{item.website ? '' : 'field-missing'}}">{{item.website || '未填写'}}</text>
          </view>
          <view class="admin-actions">
            <button class="small-btn {{item.isPublished === false ? 'small-btn--blue' : 'small-btn--danger'}}" data-index="{{index}}" catchtap="togglePublished">{{item.isPublished === false ? '上线' : '下线'}}</button>
            <button class="small-btn small-btn--yellow" data-index="{{index}}" catchtap="notifyHackathon" loading="{{notifyingId === item.id}}" disabled="{{notifyingId !== '' || item.isPublished === false}}">通知</button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{rejectTargetId}}" class="modal-mask">
    <view class="reject-modal">
      <view class="box-title">拒绝原因</view>
      <textarea class="reject-textarea" value="{{rejectReason}}" placeholder="例如：缺少官网、时间不明确、主体信息不足" bindinput="onRejectReason" />
      <view class="admin-actions">
        <button class="small-btn small-btn--white" bindtap="closeReject">取消</button>
        <button class="small-btn small-btn--danger" bindtap="confirmReject">确认拒绝</button>
      </view>
    </view>
  </view>
</view>
