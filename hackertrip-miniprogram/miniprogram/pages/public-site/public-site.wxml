<view class="focus-page public-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <!-- loading 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton">
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
        <view class="skeleton-line skeleton-line--short"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
      </view>
      <view class="skeleton-hint">加载中…</view>
    </view>

    <block wx:else>
    <view wx:if="{{loadError}}" class="brutal-box public-error">
      <view class="box-title">主页加载失败</view>
      <view class="box-copy">{{loadError}}</view>
    </view>

    <block wx:else>
    <view wx:if="{{isOwner}}" class="vis-status {{visibility.publicSite === false ? 'vis-status--hidden' : 'vis-status--public'}}">
      <text class="vis-status-label">公开主页</text>
      <text class="vis-badge vis-badge--{{visibility.publicSite === false ? 'hidden' : 'public'}}">{{visibility.publicSite === false ? '已隐藏' : '对外公开'}}</text>
    </view>

    <view class="brutal-box blue-box profile-hero">
      <view class="avatar public-avatar">
        <image wx:if="{{profile.avatarUrl}}" class="public-avatar-image" src="{{profile.avatarUrl}}" mode="aspectFill" />
        <text wx:else>{{profile.avatarChar}}</text>
      </view>
      <view class="public-info">
        <view class="focus-title public-name">{{profile.name || 'HackerTrip 用户'}}</view>
        <view wx:if="{{profile.role || profile.city}}" class="public-role">{{profile.role}}{{profile.role && profile.city ? ' · ' : ''}}{{profile.city}}</view>
        <view class="box-copy">{{profile.bio}}</view>
      </view>
    </view>

    <!-- GitHub 主页绑定：点击复制链接到浏览器打开 -->
    <view
      wx:if="{{profile.githubUrl}}"
      class="list-card github-card"
      data-url="{{profile.githubUrl}}"
      bindtap="copyWorkLink"
      hover-class="list-card--active"
    >
      <view class="github-icon">GH</view>
      <view class="github-body">
        <view class="list-title">GitHub · {{profile.githubName}}</view>
        <view class="list-subtitle">{{profile.githubUrl}}</view>
      </view>
      <view class="github-copy">复制链接</view>
    </view>

    <view class="stat-grid public-stats">
      <view class="stat-item"><text class="stat-num">{{profile.stats.hackathons}}</text><text class="stat-label">参赛</text></view>
      <view class="stat-item"><text class="stat-num">{{profile.stats.projects}}</text><text class="stat-label">作品</text></view>
      <view class="stat-item"><text class="stat-num">{{profile.stats.skills}}</text><text class="stat-label">Skills</text></view>
    </view>

    <view class="section-head section-head--flex">
      <text>技能</text>
      <text wx:if="{{isOwner}}" class="vis-badge vis-badge--{{visibility.skills === false ? 'hidden' : 'public'}}">{{visibility.skills === false ? '已隐藏' : '对外公开'}}</text>
    </view>
    <view class="chip-row">
      <text wx:for="{{profile.skills}}" wx:key="*this" class="focus-chip">{{item}}</text>
    </view>
    <view wx:if="{{!profile.skills.length}}" class="list-card">
      <view class="list-subtitle">还没有公开技能，编辑身份后会显示在这里。</view>
    </view>

    <view wx:if="{{works.length}}" class="section-head">作品 / Projects</view>
    <view wx:for="{{works}}" wx:key="id" class="list-card work-card">
      <image wx:if="{{item.cover}}" class="work-cover" src="{{item.cover}}" mode="aspectFill" />
      <view wx:else class="work-cover work-cover--empty">PROJECT</view>
      <view class="work-main">
        <view class="list-title">{{item.name}}</view>
        <view wx:if="{{item.desc}}" class="list-subtitle">{{item.desc}}</view>
        <view wx:if="{{item.awards}}" class="work-awards">🏆 {{item.awards}}</view>
        <view wx:if="{{item.tags.length}}" class="chip-row work-tags">
          <text wx:for="{{item.tags}}" wx:key="*this" class="focus-chip focus-chip--blue">{{item}}</text>
        </view>
        <view wx:if="{{item.repo || item.demo}}" class="work-actions">
          <button wx:if="{{item.repo}}" class="work-link" data-url="{{item.repo}}" bindtap="copyWorkLink">复制 Repo</button>
          <button wx:if="{{item.demo}}" class="work-link work-link--yellow" data-url="{{item.demo}}" bindtap="copyWorkLink">复制 Demo</button>
        </view>
      </view>
    </view>

    <view class="section-head section-head--flex">
      <text>作品 / 项目</text>
      <text wx:if="{{isOwner}}" class="vis-badge vis-badge--{{visibility.works === false ? 'hidden' : 'public'}}">{{visibility.works === false ? '已隐藏' : '对外公开'}}</text>
    </view>
    <view wx:for="{{projects}}" wx:key="id" class="list-card">
      <view class="list-title">{{item.name}}</view>
      <view class="list-subtitle">{{item.desc || item.subtitle}}</view>
    </view>
    <view wx:if="{{!projects.length}}" class="list-card">
      <view class="list-subtitle">还没有公开项目，作品提交后会显示在这里。</view>
    </view>

    <view class="section-head">参赛历史</view>
    <navigator
      wx:for="{{history}}"
      wx:key="id"
      class="list-card"
      url="/pages/detail/detail?id={{item.id}}"
      hover-class="list-card--active"
    >
      <view class="list-title">{{item.name}}</view>
      <view class="list-subtitle">日期 {{item.dateText}} · 城市 {{item.cityText}} · 形式 {{item.modeText}}</view>
    </navigator>
    <view wx:if="{{!history.length}}" class="list-card">
      <view class="list-subtitle">还没有加入赛程的赛事。</view>
    </view>
    </block>
    </block>
  </view>
</view>
