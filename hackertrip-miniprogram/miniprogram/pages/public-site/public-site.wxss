@import "../focus.wxss";

.profile-hero {
  display: flex;
  gap: 26rpx;
  align-items: center;
}

.public-avatar {
  flex: 0 0 132rpx;
  color: #000000;
  background: #FBD902;
  overflow: hidden;
}

.public-avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.public-info {
  flex: 1;
  min-width: 0;
}

.public-name {
  margin: 0;
  color: #FFFFFF;
}

.public-role {
  margin-top: 12rpx;
  color: #FBD902;
  font-size: 26rpx;
  font-weight: 900;
}

.public-stats {
  margin: 30rpx 0 18rpx;
}

.public-error {
  margin-top: 24rpx;
}

.work-card {
  display: flex;
  gap: 22rpx;
}

.work-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 168rpx;
  width: 168rpx;
  height: 168rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
  overflow: hidden;
}

.work-cover--empty {
  color: #000000;
  background: #FBD902;
}

.work-main {
  flex: 1;
  min-width: 0;
}

.work-awards {
  margin-top: 12rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.35;
}

.work-tags {
  margin-top: 16rpx;
}

.work-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.work-link {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 0;
  min-width: 0;
  height: 62rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.work-link--yellow {
  color: #000000;
  background: #FBD902;
}

.work-link::after {
  border: none;
}

.work-link:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

/* GitHub 主页卡 */
.github-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.github-icon {
  flex: none;
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 900; color: #FFFFFF;
  background: #000000; border: 2rpx solid #000000; border-radius: 50%;
}
.github-body { flex: 1; min-width: 0; overflow: hidden; }
.github-body .list-subtitle { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.github-copy {
  flex: none;
  padding: 10rpx 18rpx;
  font-size: 22rpx; font-weight: 900; color: #000000;
  background: #FBD902; border: 2rpx solid #000000; border-radius: 10rpx;
}
