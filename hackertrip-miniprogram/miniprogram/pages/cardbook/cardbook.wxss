.migrated-title { margin: 24rpx 0 8rpx; }

/* 当前角色卡 hero */
.cb-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}
.cb-hero-emoji { font-size: 72rpx; }
.cb-hero-body { flex: 1; min-width: 0; }
.cb-hero-name { font-size: 34rpx; font-weight: 900; color: #FFFFFF; }
.cb-hero-tag { margin-top: 6rpx; font-size: 24rpx; color: rgba(255,255,255,0.82); line-height: 1.4; }
.cb-hero-btn {
  flex-shrink: 0;
  padding: 0 24rpx; height: 64rpx; line-height: 64rpx;
  font-size: 24rpx; font-weight: 700; color: #000000;
  background: #FBD902; border: 2rpx solid #000000; border-radius: 10rpx;
}

/* 进度 */
.cb-progress {
  margin-top: 24rpx; padding: 24rpx 28rpx;
  background: #FFFFFF; border: 3rpx solid #000000; border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}
.cb-progress-head { display: flex; align-items: baseline; justify-content: space-between; }
.cb-progress-title { font-size: 30rpx; font-weight: 900; color: #000000; }
.cb-progress-count { font-size: 26rpx; font-weight: 700; color: #0C51ED; }
.cb-bar { margin: 16rpx 0 10rpx; height: 20rpx; background: #ECE8DB; border: 2rpx solid #000000; border-radius: 999rpx; overflow: hidden; }
.cb-bar-fill { height: 100%; background: #FBD902; border-right: 2rpx solid #000000; transition: width .3s; }
.cb-progress-sub { font-size: 22rpx; color: #7A7A75; }

/* 卡片网格 */
.cb-grid { margin-top: 24rpx; display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.cb-card {
  position: relative;
  padding: 28rpx 20rpx 24rpx;
  border: 3rpx solid #000000; border-radius: 16rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  min-height: 220rpx;
}
.cb-card--on { background: #FFFFFF; }
.cb-card--off { background: #ECE8DB; }
.cb-card--off .cb-card-name,
.cb-card--off .cb-card-desc { color: #7A7A75; }
.cb-card:active { transform: translate(2rpx, 2rpx); box-shadow: 3rpx 3rpx 0 0 #000000; }
.cb-rarity {
  position: absolute; top: 0; right: 0;
  padding: 4rpx 12rpx; font-size: 20rpx; font-weight: 900; color: #000000;
  border-left: 2rpx solid #000000; border-bottom: 2rpx solid #000000; border-radius: 0 12rpx 0 12rpx;
}
.cb-card-emoji { font-size: 60rpx; line-height: 1; }
.cb-card-name { margin-top: 16rpx; font-size: 28rpx; font-weight: 900; color: #000000; }
.cb-card-desc { margin-top: 8rpx; font-size: 22rpx; color: #3D3D3D; line-height: 1.4; }

/* CTA */
.cb-cta { margin-top: 28rpx; }
.cb-cta-btn {
  width: 100%; height: 92rpx; line-height: 92rpx;
  font-size: 30rpx; font-weight: 800; color: #FFFFFF;
  background: #0C51ED; border: 3rpx solid #000000; border-radius: 14rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
}
.cb-cta-btn:active { transform: translate(2rpx, 2rpx); box-shadow: 3rpx 3rpx 0 0 #000000; }
