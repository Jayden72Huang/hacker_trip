@import "../focus.wxss";

.login-content {
  padding-top: 46rpx;
}

.brand-card {
  min-height: 340rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 54rpx;
  font-weight: 900;
}

.login-title {
  color: #FFFFFF;
}

.welcome-illus {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 260rpx;
  margin: 32rpx 0;
  color: #000000;
  background: linear-gradient(135deg, #FBD902 0%, #FBD902 50%, #FFFFFF 50%, #FFFFFF 100%);
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 34rpx;
  font-weight: 900;
}

.login-btn {
  margin-top: 24rpx;
}

.agreement {
  margin-top: 28rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.55;
}
