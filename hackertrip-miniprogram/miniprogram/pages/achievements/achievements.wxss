@import "../focus.wxss";

.achievements-title {
  color: #FFFFFF;
}

.achievements-sub {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.5;
}

/* 旅行统计 */
.trip-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.trip-stat {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid #000000;
  border-radius: 12rpx;
}
.trip-stat-num { color: #FBD902; font-size: 44rpx; font-weight: 900; line-height: 1.1; }
.trip-stat-label { margin-top: 6rpx; color: #FFFFFF; font-size: 22rpx; font-weight: 700; }

/* 旅程时间线 */
.trip-section-title {
  margin: 28rpx 4rpx 4rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #000000;
}
.trip-stop { position: relative; }
.trip-stop:active { transform: translate(2rpx, 2rpx); }
.trip-stop-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.trip-stop-date { font-size: 24rpx; font-weight: 800; color: #7A7A75; }
.trip-stop-status {
  flex: none;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #000000;
  background: #ECE8DB;
  border: 2rpx solid #000000;
  border-radius: 999rpx;
}
.trip-stop-status--ongoing { background: #FBD902; }
.trip-stop-status--upcoming { background: #FFFFFF; }
.trip-stop-status--ended { background: #ECE8DB; }
.trip-stop-name {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #000000;
}
.trip-stop-place { margin-top: 8rpx; font-size: 24rpx; color: #3D3D3D; }

/* 认证徽章 */
.trip-badges { margin-top: 18rpx; display: flex; flex-direction: column; gap: 12rpx; }
.trip-badge {
  padding: 12rpx 16rpx;
  background: #ECF2FF;
  border: 2rpx solid #0C51ED;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #000000;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.trip-badge--award {
  background: #FFF7D6;
  border-color: #B8860B;
}
.trip-badge-verified {
  font-size: 20rpx;
  font-weight: 700;
  color: #0C51ED;
}
.trip-badge--award .trip-badge-verified { color: #8A6D00; }

.trip-footnote {
  margin: 24rpx 4rpx 40rpx;
  font-size: 22rpx;
  color: #7A7A75;
  line-height: 1.5;
}

/* 表单字段（与验证页保持一致的样式） */
.form-field {
  margin-top: 24rpx;
}
.field-label {
  margin-bottom: 10rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}
.picker-box {
  width: 100%;
  box-sizing: border-box;
  min-height: 86rpx;
  padding: 22rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

/* 待验证徽章（本人添加、还没被主办方盖章） */
.trip-badge-pending {
  font-size: 20rpx;
  font-weight: 700;
  color: #B8860B;
}

/* 领取奖杯 / 添加履历 入口 */
.trip-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
.trip-action-btn {
  flex: 1;
}
.trip-action-btn--on {
  transform: translate(2rpx, 2rpx);
}

/* 折叠表单面板 */
.trip-panel {
  margin-top: 20rpx;
}
.trip-panel-submit {
  margin-top: 20rpx;
  width: 100%;
}
.trip-code-input {
  text-transform: uppercase;
  letter-spacing: 4rpx;
  font-weight: 900;
}
.trip-upload-btn {
  width: 100%;
}

/* 获奖截图缩略图 */
.trip-proof-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}
.trip-proof-thumb {
  width: 160rpx;
  height: 160rpx;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  background: #FFFFFF;
}
.trip-proof-remove {
  font-size: 24rpx;
  font-weight: 800;
  color: #C0392B;
  text-decoration: underline;
}

/* 产品/作品链接（点按复制） */
.trip-product-link {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-top: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #0C51ED;
}
