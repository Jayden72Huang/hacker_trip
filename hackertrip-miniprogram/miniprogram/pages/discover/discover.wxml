<view class="page page--tab discovery-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="hero">
      <view class="hero-brand">
        <image class="hero-logo" src="/images/logo-transparent.png" mode="aspectFit" />
        <view class="hero-copy">
          <view class="page-title">发现黑客松</view>
          <view class="page-subtitle">HackerTrip-助你探索好玩的黑客松赛事</view>
        </view>
      </view>
    </view>

    <!-- loading 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton">
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
        <view class="skeleton-line skeleton-line--short"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
        <view class="skeleton-line skeleton-line--short"></view>
      </view>
      <view class="skeleton-hint">加载中…</view>
    </view>

    <!-- 内容区 -->
    <block wx:else>
    <view class="featured-switch">
        <button
          class="featured-switch-item {{activeFeaturedTab === 'featured' ? 'featured-switch-item--active' : ''}}"
          data-tab="featured"
          bindtap="onFeaturedTabTap"
        >精选推荐</button>
        <button
          class="featured-switch-item {{activeFeaturedTab === 'mine' ? 'featured-switch-item--active' : ''}}"
          data-tab="mine"
          bindtap="onFeaturedTabTap"
        >适合我的</button>
    </view>
    <view class="featured-head-line"></view>
    <view wx:if="{{activeFeaturedTab === 'mine' && recommendationState === 'login'}}" class="recommendation-guide">
      <view class="recommendation-guide-copy">
        <view class="recommendation-guide-title">登录后生成个人推荐</view>
        <view class="recommendation-guide-text">用你的技能、GitHub、作品和 Skills 同步结果匹配更适合的黑客松。</view>
      </view>
      <button class="recommendation-guide-btn" bindtap="openRecommendationLogin">微信登录</button>
    </view>
    <view wx:elif="{{activeFeaturedTab === 'mine' && recommendationState === 'profile'}}" class="recommendation-guide">
      <view class="recommendation-guide-copy">
        <view class="recommendation-guide-title">补充资料后更准确</view>
        <view class="recommendation-guide-text">完善技能、GitHub 或同步 Skills，推荐会更贴合你的阶段和能力。</view>
      </view>
      <view class="recommendation-guide-actions">
        <button class="recommendation-guide-btn recommendation-guide-btn--ghost" bindtap="goEditProfile">编辑资料</button>
        <button class="recommendation-guide-btn" bindtap="goSyncSkills">同步 Skills</button>
      </view>
    </view>
    <view wx:if="{{activeFeaturedTab === 'mine' && recommendationState === 'ready' && recommendationHint}}" class="recommendation-hint">{{recommendationHint}}</view>
    <scroll-view wx:if="{{featured.length}}" class="featured-scroll" scroll-x enable-flex>
      <navigator
        wx:for="{{featured}}"
        wx:key="id"
        class="featured-card"
        url="/pages/detail/detail?id={{item.id}}"
        hover-class="featured-card--active"
      >
        <view class="featured-title">{{item.shortName || item.name}}</view>
        <view wx:if="{{activeFeaturedTab === 'mine' && item.fitReason}}" class="featured-reason">{{item.fitReason}}</view>
        <view class="featured-info">
          <view class="featured-info-row">
            <text class="featured-info-label">时间</text>
            <text class="featured-info-value">{{item.featuredDateText || '待确认'}}</text>
          </view>
          <view class="featured-info-row">
            <text class="featured-info-label">地点</text>
            <text class="featured-info-value featured-info-value--location">{{item.location || item.city || '待确认'}}</text>
          </view>
          <view class="featured-info-row featured-info-row--split">
            <view class="featured-inline">
              <text class="featured-info-label">模式</text>
              <text class="featured-mode-pill">{{item.modeText || '待确认'}}</text>
            </view>
            <view class="featured-inline featured-inline--prize">
              <text class="featured-info-label">奖金</text>
              <text class="featured-info-value featured-prize">{{item.prizePool || '待确认'}}</text>
            </view>
          </view>
        </view>
      </navigator>
    </scroll-view>
    <view wx:elif="{{activeFeaturedTab === 'mine'}}" class="recommendation-empty">
      完成上方操作后，这里只展示真正适合你的黑客松。
    </view>

    <view class="list-head">
      <view class="section-title list-head-title">更多黑客松</view>
      <view class="list-head-line"></view>
    </view>

    <view class="search-row">
      <view class="city-row search-city" bindtap="openCityPicker">
        <text class="city-name">{{city}}</text>
        <text class="city-caret">▾</text>
      </view>
      <view class="search-box">
        <view class="icon-search" />
        <input
          class="search-input"
          value="{{query}}"
          placeholder="搜索更多黑客松"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <button wx:if="{{query}}" class="search-clear" aria-label="清空搜索" bindtap="clearSearch">×</button>
      </view>
      <view class="sort-chip" bindtap="openSortPicker">
        <text>{{sortLabel}}</text>
        <text class="sort-caret">▾</text>
      </view>
      <view wx:if="{{sortPickerVisible}}" class="sort-popover">
        <view
          wx:for="{{sortOptions}}"
          wx:key="key"
          class="sort-popover-item {{sortKey === item.key ? 'on' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSortPick"
        >{{item.label}}</view>
      </view>
    </view>

    <hackathon-card
      wx:for="{{hackathons}}"
      wx:key="id"
      item="{{item}}"
      bookmarked="{{item.bookmarked}}"
      bind:bookmark="onBookmark"
      bind:tapcard="goDetail"
      bind:register="onRegister"
    />

    <!-- 搜索 / 筛选后无结果的空态（区别于 loading） -->
    <view wx:if="{{hackathons.length === 0}}" class="empty-state">
      <view class="empty-state-title">没找到匹配的黑客松</view>
      <view class="empty-state-text">换个关键词或筛选条件再试试。</view>
    </view>

    <view class="list-head partners-head">
      <view class="section-title list-head-title">合作伙伴</view>
      <view class="list-head-line"></view>
    </view>
    <view class="partners-cloud">
      <image
        wx:for="{{partners}}"
        wx:key="id"
        class="partner-logo partner-logo--{{item.id}}"
        src="{{item.logo}}"
        mode="aspectFit"
      />
    </view>
    <view class="partners-divider"></view>
    <view class="partners-slogan">HackerTrip 携手主办方，把黑客松做成开发者的游乐场 🎡</view>
    </block>
  </view>

  <page-container show="{{cityPickerVisible}}" round bindbeforeleave="closeCityPicker" bindclickoverlay="closeCityPicker">
    <view class="city-picker">
      <view class="city-picker-title">选择城市</view>
      <scroll-view scroll-y class="city-picker-list">
        <view
          wx:for="{{cities}}"
          wx:key="*this"
          class="city-picker-item {{city === item ? 'on' : ''}}"
          data-city="{{item}}"
          bindtap="onCityPick"
        >{{item}}</view>
      </scroll-view>
    </view>
  </page-container>
  <auth-modal id="authModal" />
</view>
