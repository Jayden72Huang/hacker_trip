@import "../focus.wxss";

.page {
  padding: 28rpx 40rpx 0;
}
.seg {
  display: flex;
  padding: 8rpx;
  border-radius: 999rpx;
  margin-bottom: 28rpx;
  background: #f4f2ec;
}

.identity-flow {
  margin-bottom: 26rpx;
  background: #FFFFFF;
}

.flow-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.flow-step {
  min-width: 0;
  padding: 16rpx 12rpx;
  background: #F4F1E8;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
}

.flow-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 2rpx solid #000000;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.flow-title {
  margin-top: 12rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

.flow-copy {
  margin-top: 6rpx;
  color: #3D3D3D;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.3;
}

.flow-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.flow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 66rpx;
  margin: 0;
  padding: 0 8rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.15;
}

.flow-btn--yellow {
  color: #000000;
  background: #FBD902;
}

.flow-btn::after {
  border: none;
}

.identity-section-head {
  margin: 20rpx 0 18rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #6b6862;
  border-radius: 999rpx;
}
.seg-item.on {
  color: #fff;
  background: #c96442;
}
.sync-pill {
  text-align: center;
  font-size: 22rpx;
  color: #c96442;
  margin-bottom: 16rpx;
}
.preview {
  display: flex;
  justify-content: center;
  padding: 10rpx 0 24rpx;
}

.stats-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  padding: 18rpx 12rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.card-canvas {
  border-radius: 28rpx;
  box-shadow: 0 20rpx 56rpx rgba(201, 100, 66, 0.2);
}

.role-panel {
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}
.panel-toggle,
.config-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}
.panel-arrow {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.panel-body,
.config-body {
  margin-top: 22rpx;
}
.role-head {
  display: flex;
  align-items: center;
}
.role-emoji {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.role-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.role-tag {
  font-size: 23rpx;
  color: #6b6862;
  margin-top: 4rpx;
}
.reasons {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.reason {
  font-size: 22rpx;
  color: #94918a;
}
.role-switch {
  margin-top: 18rpx;
}
.rs-label {
  font-size: 22rpx;
  color: #6b6862;
}
.rs-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}
.rs-chip {
  display: inline-block;
  font-size: 20rpx;
  color: #6b6862;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.rs-chip.on {
  color: #fff;
  background: #c96442;
  border-color: #c96442;
}

.form-label {
  font-size: 26rpx;
  color: #1f1e1d;
  font-weight: 600;
  margin: 26rpx 0 14rpx;
}
.form {
  padding: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}
.config-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}
.config-copy {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}
.selected,
.preset-row,
.opt-row {
  display: flex;
  flex-wrap: wrap;
}
.add-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}
.add-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1f1e1d;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.ph {
  color: #94918a;
}
.add-btn {
  width: 76rpx;
  height: 76rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  color: #c96442;
  border-radius: 16rpx;
  background: #f4ede4;
  border: 1rpx solid #efe6da;
}
.opt {
  padding: 14rpx 28rpx;
  margin: 0 14rpx 14rpx 0;
  border-radius: 16rpx;
  font-size: 25rpx;
  color: #6b6862;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.opt.on {
  color: #fff;
  background: #c96442;
  border-color: #c96442;
}

.actionbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #ece9e0;
}
.act-save {
  flex: 1;
}
.share-wrap {
  flex: 1.4;
  min-width: 0;
}
.act-share {
  width: 100%;
  margin: 0;
}
.act-share.is-disabled {
  color: #6F6F6F;
  background: #E7E4DC;
}
.share-status {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.15;
  text-align: center;
}

.identity-ai {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.migrated-title {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.seg,
.role-panel,
.add-input,
.add-btn,
.opt,
.rs-chip,
.actionbar {
  border: 4rpx solid #000000;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.seg-item.on,
.rs-chip.on,
.opt.on {
  color: #FFFFFF;
  background: #0C51ED;
  border-color: #000000;
}

.sync-pill,
.role-name,
.form-label {
  color: #000000;
}

.role-tag,
.reason,
.rs-label,
.seg-item {
  color: #3D3D3D;
}

.card-canvas {
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}
