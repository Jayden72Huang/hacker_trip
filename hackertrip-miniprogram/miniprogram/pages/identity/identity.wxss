@import "../focus.wxss";

.page {
  padding: 28rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
}
.identity-flow {
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.flow-head {
  margin-bottom: 22rpx;
}

.flow-kicker {
  display: inline-flex;
  padding: 6rpx 14rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.flow-heading {
  margin-top: 16rpx;
  color: #000000;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.22;
}

.flow-sub {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.flow-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.flow-step {
  min-width: 0;
  padding: 20rpx;
  background: #F4F1E8;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
}

.flow-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 2rpx solid #000000;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.flow-title {
  margin-top: 12rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

.flow-copy {
  margin-top: 6rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.42;
}

.flow-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.flow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 66rpx;
  margin: 18rpx 0 0;
  padding: 0 8rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.15;
}

.flow-btn--yellow {
  color: #000000;
  background: #FBD902;
}

.flow-btn--share.is-disabled,
.flow-btn--yellow.is-disabled,
.flow-btn--preview.is-disabled {
  color: #6F6F6F;
  background: #E7E4DC;
  box-shadow: 3rpx 3rpx 0 0 #000000;
}

.flow-btn::after {
  border: none;
}

.flow-actions--inline {
  margin-top: 18rpx;
}

.flow-actions--inline .flow-btn {
  flex: 1;
  margin-top: 0;
}

.style-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.style-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
}

.style-chip.on {
  color: #FFFFFF;
  background: #0C51ED;
}

.flow-share-status {
  margin-top: 12rpx;
}

.identity-section-head {
  margin: 20rpx 0 18rpx;
}
.sync-pill {
  text-align: center;
  font-size: 22rpx;
  color: #c96442;
  margin-bottom: 16rpx;
}
.preview {
  position: relative;
  display: flex;
  justify-content: center;
  padding: 8rpx 0 16rpx;
  overflow: hidden;
}

/* 未生成预览时的占位卡 */
.preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 540rpx;
  min-height: 420rpx;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  text-align: center;
  background: #F4F1E8;
  border: 3rpx dashed #0C51ED;
  border-radius: 18rpx;
}
.preview-empty-icon {
  font-size: 64rpx;
  line-height: 1;
}
.preview-empty-title {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
}
.preview-empty-copy {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #55524A;
}

/* canvas 不能销毁重建，未生成时移出可视区保持节点存活 */
.card-canvas--offstage {
  position: absolute;
  left: -9999rpx;
  top: 0;
}

/* 当前角色：只读一行 */
.role-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 20rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}
.role-line__emoji {
  font-size: 40rpx;
  line-height: 1;
}
.role-line__text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.role-line__name {
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
  line-height: 1.2;
}
.role-line__tag {
  margin-top: 2rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #3D3D3D;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 同步 Skills 入口（高级配置内） */
.sync-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin: 0 0 8rpx;
  color: #0C51ED;
  background: #F4F1E8;
  border: 3rpx dashed #0C51ED;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}
.sync-entry::after {
  border: none;
}

.stats-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0; /* 覆盖原生 button 默认最小宽度，防止撑破三列 grid */
  box-sizing: border-box;
  padding: 18rpx 12rpx;
  margin: 0;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  text-align: center;
}

.stat-card::after {
  border: none;
}

.stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}
.card-canvas {
  border-radius: 28rpx;
  box-shadow: 0 20rpx 56rpx rgba(201, 100, 66, 0.2);
}

.data-panel {
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.data-title {
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.data-copy {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 66rpx;
  margin: 18rpx 0 0;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
}

.refresh-btn::after {
  border: none;
}

.role-panel {
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}
.panel-toggle,
.config-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}
.panel-arrow {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.panel-body,
.config-body {
  margin-top: 22rpx;
}
.role-head {
  display: flex;
  align-items: center;
}
.role-emoji {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.role-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.role-tag {
  font-size: 23rpx;
  color: #6b6862;
  margin-top: 4rpx;
}
.reasons {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.reason {
  font-size: 22rpx;
  color: #94918a;
}
.role-switch {
  margin-top: 18rpx;
}
.rs-label {
  font-size: 22rpx;
  color: #6b6862;
}
.rs-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}
.rs-chip {
  display: inline-block;
  font-size: 20rpx;
  color: #6b6862;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.rs-chip.on {
  color: #fff;
  background: #c96442;
  border-color: #c96442;
}

.form-label {
  font-size: 26rpx;
  color: #1f1e1d;
  font-weight: 600;
  margin: 26rpx 0 14rpx;
}
.form {
  padding: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}
.config-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}
.config-copy {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}
.selected,
.preset-row,
.opt-row {
  display: flex;
  flex-wrap: wrap;
}
.add-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}
.add-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1f1e1d;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.ph {
  color: #94918a;
}
.add-btn {
  width: 76rpx;
  height: 76rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  color: #c96442;
  border-radius: 16rpx;
  background: #f4ede4;
  border: 1rpx solid #efe6da;
}
.opt {
  padding: 14rpx 28rpx;
  margin: 0 14rpx 14rpx 0;
  border-radius: 16rpx;
  font-size: 25rpx;
  color: #6b6862;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.opt.on {
  color: #fff;
  background: #c96442;
  border-color: #c96442;
}

.share-status {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.15;
  text-align: center;
}

.identity-ai {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.migrated-title {
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.role-panel,
.add-input,
.add-btn,
.opt,
.rs-chip {
  border: 4rpx solid #000000;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.rs-chip.on,
.opt.on {
  color: #FFFFFF;
  background: #0C51ED;
  border-color: #000000;
}

.sync-pill,
.role-name,
.form-label {
  color: #000000;
}

.role-tag,
.reason,
.rs-label {
  color: #3D3D3D;
}

.card-canvas {
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

/* 组队暗号（裂变发起端） */
.flow-invite {
  margin-top: 14rpx; padding: 14rpx 20rpx;
  font-size: 24rpx; font-weight: 700; color: #3D3D3D;
  background: #ECF2FF; border: 2rpx dashed #0C51ED; border-radius: 10rpx;
}
.flow-invite:active { opacity: 0.7; }
.flow-invite-code { color: #0C51ED; font-weight: 900; letter-spacing: 2rpx; }
