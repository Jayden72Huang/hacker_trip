<navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
<view class="page-title migrated-title">{{title}}</view>
<view wx:if="{{aiBanner}}" class="ai-banner identity-ai"><text>来自微信AI助手</text><text>{{aiIntentText}}</text></view>
<wxs src="../../utils/tools.wxs" module="tools" />
<view class="page">
  <!-- 变体切换 -->
  <view class="seg glass">
    <view class="seg-item {{variant === 'identity' ? 'on' : ''}}" data-v="identity" bindtap="switchVariant">🎴 身份卡</view>
    <view class="seg-item {{variant === 'config' ? 'on' : ''}}" data-v="config" bindtap="switchVariant">🧩 配置卡</view>
  </view>

  <view wx:if="{{fromSync}}" class="sync-pill">✨ 已从 Skills 扫描结果预填</view>

  <!-- Canvas 预览 -->
  <view class="preview">
    <canvas type="2d" id="cardCanvas" class="card-canvas" style="width: 540rpx; height: 720rpx;" />
  </view>

  <view class="stats-panel">
    <view class="stat-card">
      <text class="stat-num">{{stats.hackathons}}</text>
      <text class="stat-label">参赛</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.projects}}</text>
      <text class="stat-label">作品</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{techStack.length}}</text>
      <text class="stat-label">Skills</text>
    </view>
  </view>

  <!-- 角色判定面板 -->
  <view class="role-panel glass">
    <view class="role-head">
      <text class="role-emoji">{{roleMeta.emoji}}</text>
      <view class="role-info">
        <view class="role-name">{{roleMeta.name}}</view>
        <view class="role-tag">{{roleMeta.tagline}}</view>
      </view>
    </view>
    <view wx:if="{{reasons.length}}" class="reasons">
      <text wx:for="{{reasons}}" wx:key="*this" class="reason">· {{item}}</text>
    </view>
    <view class="role-switch">
      <text class="rs-label">不认同？锁定主角色：</text>
      <scroll-view scroll-x class="rs-scroll" enhanced show-scrollbar="{{false}}">
        <text
          wx:for="{{roleList}}"
          wx:key="key"
          class="rs-chip {{role === item.key ? 'on' : ''}}"
          data-key="{{item.key}}"
          bindtap="lockRole"
        >{{item.emoji}} {{item.name}}</text>
      </scroll-view>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form">
    <view class="form-label">主技术栈</view>
    <view class="selected">
      <text wx:for="{{techStack}}" wx:key="*this" class="chip chip-accent" data-idx="{{index}}" bindtap="removeTech">{{item}} ✕</text>
    </view>
    <view class="preset-row">
      <text
        wx:for="{{techPresets}}" wx:key="*this"
        class="chip {{tools.inArray(techStack, item) ? 'chip-accent' : ''}}"
        data-field="techStack" data-value="{{item}}" bindtap="togglePreset"
      >{{item}}</text>
    </view>
    <view class="add-row">
      <input class="add-input" placeholder="自定义技术，回车添加" placeholder-class="ph" value="{{techInput}}" bindinput="onTechInput" bindconfirm="addTech" />
      <view class="add-btn" bindtap="addTech">＋</view>
    </view>

    <view class="form-label">AI 工具</view>
    <view class="preset-row">
      <text
        wx:for="{{aiPresets}}" wx:key="*this"
        class="chip {{tools.inArray(aiTools, item) ? 'chip-accent' : ''}}"
        data-field="aiTools" data-value="{{item}}" bindtap="togglePreset"
      >{{item}}</text>
    </view>

    <view class="form-label">打法风格</view>
    <view class="opt-row">
      <view
        wx:for="{{playStyles}}" wx:key="key"
        class="opt {{playStyleIdx === index ? 'on' : ''}}"
        data-idx="{{index}}" bindtap="pickPlay"
      >{{item.emoji}} {{item.label}}</view>
    </view>

    <view class="form-label">组队状态</view>
    <view class="opt-row">
      <view
        wx:for="{{lookingFors}}" wx:key="key"
        class="opt {{lookingForIdx === index ? 'on' : ''}}"
        data-idx="{{index}}" bindtap="pickLooking"
      >{{item.emoji}} {{item.label}}</view>
    </view>
  </view>

  <view style="height: 180rpx;" />
</view>

<!-- 底部操作栏 -->
<view class="actionbar glass-strong">
  <button class="btn-ghost act-save" bindtap="saveToAlbum">{{saving ? '保存中…' : '保存图片'}}</button>
  <button class="btn-primary act-share" open-type="share">分享 / 找队友</button>
</view>
