<navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
<view wx:if="{{aiBanner}}" class="ai-banner identity-ai"><text>来自微信AI助手</text><text>{{aiIntentText}}</text></view>
<wxs src="../../utils/tools.wxs" module="tools" />
<view class="page">
  <view wx:if="{{fromSync}}" class="sync-pill">✨ 已从 Skills 扫描结果预填</view>

  <!-- 身份卡生成流程：每一步内放对应操作 -->
  <view class="identity-flow">
    <view class="flow-head">
      <view class="flow-kicker">Identity Card</view>
      <view class="flow-heading">把已有参赛数据整理成一张可分享身份卡</view>
      <view class="flow-sub">先补身份资料，再选择卡片风格，最后导出图片或直接转发给队友。</view>
    </view>
    <view class="flow-row">
      <view class="flow-step">
        <text class="flow-index">1</text>
        <view class="flow-title">完善身份信息</view>
        <view class="flow-copy">填写昵称、城市、角色、GitHub 和可交付的 Skills。</view>
        <button class="flow-btn" bindtap="goEditProfile">去完善资料</button>
      </view>
      <view class="flow-step">
        <text class="flow-index">2</text>
        <view class="flow-title">选择卡片风格</view>
        <view class="flow-copy">身份卡适合社群分享；配置卡适合展示 Agent / Skills 上下文。</view>
        <view class="style-switch">
          <view class="style-chip {{variant === 'identity' ? 'on' : ''}}" data-v="identity" bindtap="switchVariant">身份卡</view>
          <view class="style-chip {{variant === 'config' ? 'on' : ''}}" data-v="config" bindtap="switchVariant">配置卡</view>
        </view>
      </view>
      <view class="flow-step">
        <text class="flow-index">3</text>
        <view class="flow-title">导出分享</view>
        <view class="flow-copy">保存图片到相册，或转发带公开主页入口的身份卡。</view>
        <view class="flow-actions flow-actions--inline">
          <button class="flow-btn flow-btn--yellow" bindtap="saveToAlbum">{{saving || savingCard ? '保存中…' : '保存图片'}}</button>
          <button class="flow-btn flow-btn--share {{qrReady ? '' : 'is-disabled'}}" open-type="share" disabled="{{!qrReady}}" bindtap="prepareShare">
            {{qrReady ? '分享卡片' : '生成中…'}}
          </button>
        </view>
        <view class="share-status flow-share-status">{{qrReady ? (cardSaved ? '已保存到我的 · 可转发' : '已绑定公开主页') : (qrError || '正在生成小程序码')}}</view>
      </view>
    </view>
  </view>

  <!-- 卡片预览（首屏主角） -->
  <view class="preview">
    <canvas type="2d" id="cardCanvas" class="card-canvas" style="width: 540rpx; height: 720rpx;" />
  </view>

  <!-- 当前角色（只读一行） -->
  <view class="role-line">
    <text class="role-line__emoji">{{roleMeta.emoji}}</text>
    <view class="role-line__text">
      <text class="role-line__name">{{roleMeta.name}}</text>
      <text class="role-line__tag">{{roleMeta.tagline}}</text>
    </view>
  </view>

  <!-- 卡片数据来源 -->
  <view class="data-panel">
    <view class="data-title">将写入卡片的数据</view>
    <view class="data-copy">身份卡会整合当前档案、参赛记录、作品和 Skills；修改后点刷新会重新绘制预览。</view>
    <button class="refresh-btn" bindtap="regenerateCard">刷新预览</button>
    <view class="stats-panel">
      <button class="stat-card" data-target="hackathons" bindtap="openAsset">
        <text class="stat-num">{{stats.hackathons}}</text>
        <text class="stat-label">参赛经历</text>
      </button>
      <button class="stat-card" data-target="works" bindtap="openAsset">
        <text class="stat-num">{{stats.projects}}</text>
        <text class="stat-label">作品列表</text>
      </button>
      <button class="stat-card" data-target="skills" bindtap="openAsset">
        <text class="stat-num">{{techStack.length}}</text>
        <text class="stat-label">我的 Skills</text>
      </button>
    </view>
  </view>

  <!-- 高级配置：默认收起，点开才显示全部编辑项 -->
  <view class="form">
    <view class="config-toggle" bindtap="toggleConfigPanel">
      <view>
        <view class="config-title">高级配置</view>
        <view class="config-copy">角色、技术栈、AI 工具、打法风格和组队状态</view>
      </view>
      <view class="panel-arrow">{{configPanelOpen ? '收起' : '展开'}}</view>
    </view>
    <view wx:if="{{configPanelOpen}}" class="config-body">
      <button class="sync-entry" bindtap="goSyncSkills">↻ 从 Skills 扫描自动填技术栈</button>

      <view class="form-label">主角色</view>
      <view wx:if="{{reasons.length}}" class="reasons">
        <text wx:for="{{reasons}}" wx:key="*this" class="reason">· {{item}}</text>
      </view>
      <scroll-view scroll-x class="rs-scroll" enhanced show-scrollbar="{{false}}">
        <text
          wx:for="{{roleList}}"
          wx:key="key"
          class="rs-chip {{role === item.key ? 'on' : ''}}"
          data-key="{{item.key}}"
          bindtap="lockRole"
        >{{item.emoji}} {{item.name}}</text>
      </scroll-view>

      <view class="form-label">主技术栈</view>
      <view class="selected">
        <text wx:for="{{techStack}}" wx:key="*this" class="chip chip-accent" data-idx="{{index}}" bindtap="removeTech">{{item}} ✕</text>
      </view>
      <view class="preset-row">
        <text
          wx:for="{{techPresets}}" wx:key="*this"
          class="chip {{tools.inArray(techStack, item) ? 'chip-accent' : ''}}"
          data-field="techStack" data-value="{{item}}" bindtap="togglePreset"
        >{{item}}</text>
      </view>
      <view class="add-row">
        <input class="add-input" placeholder="自定义技术，回车添加" placeholder-class="ph" value="{{techInput}}" bindinput="onTechInput" bindconfirm="addTech" />
        <view class="add-btn" bindtap="addTech">＋</view>
      </view>

      <view class="form-label">AI 工具</view>
      <view class="preset-row">
        <text
          wx:for="{{aiPresets}}" wx:key="*this"
          class="chip {{tools.inArray(aiTools, item) ? 'chip-accent' : ''}}"
          data-field="aiTools" data-value="{{item}}" bindtap="togglePreset"
        >{{item}}</text>
      </view>

      <view class="form-label">打法风格</view>
      <view class="opt-row">
        <view
          wx:for="{{playStyles}}" wx:key="key"
          class="opt {{playStyleIdx === index ? 'on' : ''}}"
          data-idx="{{index}}" bindtap="pickPlay"
        >{{item.emoji}} {{item.label}}</view>
      </view>

      <view class="form-label">组队状态</view>
      <view class="opt-row">
        <view
          wx:for="{{lookingFors}}" wx:key="key"
          class="opt {{lookingForIdx === index ? 'on' : ''}}"
          data-idx="{{index}}" bindtap="pickLooking"
        >{{item.emoji}} {{item.label}}</view>
      </view>
    </view>
  </view>
</view>
<auth-modal id="authModal" bind:login="onAuthLogin" />
