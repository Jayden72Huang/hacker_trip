.hackathon-list-page {
  min-height: 100vh;
  background: #F4F1E8;
}

.content {
  padding: 0 32rpx 60rpx;
}

/* 城市 + 搜索 */
.list-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.city-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 24rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  flex-shrink: 0;
}

.city-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
}

.city-caret {
  font-size: 22rpx;
  color: #0C51ED;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  padding: 18rpx 24rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.sort-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 16rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
}

.sort-caret {
  color: #0C51ED;
  font-size: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #000000;
}

.search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 46rpx !important;
  height: 46rpx;
  padding: 0;
  margin: 0;
  color: #FFFFFF;
  background: #000000;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.search-clear::after {
  border: none;
}

/* 筛选标签 */
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-chip {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 999rpx;
}

.filter-chip.on {
  color: #FFFFFF;
  background: #0C51ED;
}

.list-count {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #6B6B6B;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 空态 */
.list-empty {
  padding: 80rpx 40rpx;
  text-align: center;
}

.list-empty-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #000000;
}

.list-empty-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6B6B6B;
}

/* 城市选择器 */
.city-picker {
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #F4F1E8;
  border-top: 4rpx solid #000000;
}

.city-picker-title {
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #000000;
}

.city-picker-list {
  max-height: 720rpx;
}

.city-picker-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.city-picker-item.on {
  color: #FFFFFF;
  background: #0C51ED;
}

.sort-picker {
  padding: 32rpx 32rpx calc(96rpx + env(safe-area-inset-bottom));
  background: #F4F1E8;
  border-top: 4rpx solid #000000;
}

.sort-picker-title {
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #000000;
}

.sort-picker-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.sort-picker-item.on {
  color: #FFFFFF;
  background: #0C51ED;
}
