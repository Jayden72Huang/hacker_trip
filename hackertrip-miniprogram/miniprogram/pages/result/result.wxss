.page {
  padding: 36rpx 40rpx 0;
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-emoji {
  font-size: 90rpx;
}
.empty-text {
  margin-top: 20rpx;
  color: #6b6862;
  font-size: 27rpx;
}
.empty-btn {
  margin-top: 40rpx;
  width: 360rpx;
}

.profile {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #ece9e0;
}
.profile-label {
  font-size: 23rpx;
  color: #6b6862;
}
.profile-name {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #1f1e1d;
}
.profile-domain {
  margin-top: 4rpx;
  font-size: 25rpx;
  color: #c96442;
}
.profile-sum {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6b6862;
  line-height: 1.6;
}
.profile-stack {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.match-title {
  margin: 36rpx 0 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.match {
  padding: 32rpx;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #ece9e0;
}
.match-head {
  display: flex;
  align-items: center;
}
.match-rank {
  font-size: 26rpx;
  font-weight: 800;
  color: #c96442;
  margin-right: 16rpx;
}
.match-name {
  flex: 1;
  font-size: 29rpx;
  font-weight: 600;
  color: #1f1e1d;
}
.match-score {
  font-size: 34rpx;
  font-weight: 800;
  color: #c96442;
}
.match-bar {
  height: 10rpx;
  border-radius: 999rpx;
  background: #f4ede4;
  margin: 16rpx 0;
  overflow: hidden;
}
.match-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c96442, #e0915f);
}
.match-track {
  font-size: 23rpx;
  color: #c96442;
}
.match-pitch {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b6862;
  line-height: 1.6;
}
.match-go {
  margin-top: 16rpx;
  font-size: 23rpx;
  color: #c96442;
}

.cta {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(120deg, rgba(201, 100, 66, 0.14), rgba(201, 100, 66, 0.06));
  border: 1rpx solid rgba(201, 100, 66, 0.3);
}
.cta-emoji {
  font-size: 52rpx;
  margin-right: 20rpx;
}
.cta-text {
  flex: 1;
}
.cta-t {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.cta-d {
  font-size: 22rpx;
  color: #6b6862;
  margin-top: 6rpx;
}
.cta-a {
  font-size: 40rpx;
  color: #c96442;
}
