.page {
  padding: 36rpx 40rpx 72rpx;
}
.head-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #1f1e1d;
}
.head-sub {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #6b6862;
  line-height: 1.6;
}

.synced {
  margin-top: 36rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #ece9e0;
  box-shadow: 0 12rpx 32rpx rgba(60, 50, 40, 0.08);
}
.synced-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.synced-badge {
  font-size: 26rpx;
  color: #3f9c6a;
  font-weight: 700;
}
.synced-src {
  font-size: 21rpx;
  color: #94918a;
}
.synced-proj {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1e1d;
}
.synced-stack {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}
.synced-matches {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: #c96442;
}
.synced-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}
.synced-actions .btn-ghost,
.synced-actions .btn-primary {
  flex: 1;
  height: 80rpx;
  font-size: 27rpx;
}

.pair {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #ece9e0;
  box-shadow: 0 12rpx 32rpx rgba(60, 50, 40, 0.08);
}
.pair-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1e1d;
}
.pair-row {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}
.pair-input {
  flex: 1;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  letter-spacing: 8rpx;
  color: #1f1e1d;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
}
.ph {
  color: #94918a;
  letter-spacing: 0;
}
.pair-btn {
  width: 180rpx;
  height: 88rpx;
}
.demo-link {
  margin-top: 18rpx;
  font-size: 23rpx;
  color: #c96442;
}

.steps {
  margin-top: 40rpx;
}
.steps-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1e1d;
  margin-bottom: 18rpx;
}
.step {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border: 1rpx solid #ece9e0;
  box-shadow: 0 12rpx 32rpx rgba(60, 50, 40, 0.08);
}
.step-n {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 700;
  color: #9c6a3f;
  background: #f4ede4;
  border: 1rpx solid #ece9e0;
  margin-right: 20rpx;
}
.step-t {
  font-size: 27rpx;
  font-weight: 600;
  color: #1f1e1d;
}
.step-d {
  font-size: 23rpx;
  color: #6b6862;
  margin-top: 6rpx;
  line-height: 1.5;
}
.install-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  background: #f4f2ec;
  border: 1rpx solid #ece9e0;
  box-shadow: none;
}
.install-code {
  font-size: 22rpx;
  color: #c96442;
  font-family: "SF Mono", Menlo, monospace;
}
.install-copy {
  font-size: 23rpx;
  color: #9c6a3f;
}
.privacy {
  margin-top: 22rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94918a;
}
