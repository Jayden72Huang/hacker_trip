@import "../focus.wxss";

.pair-input {
  height: 112rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
  text-align: center;
}

.sync-status {
  margin-top: 26rpx;
  color: #000000;
  font-size: 25rpx;
  font-weight: 800;
}

.sync-btn {
  margin-top: 24rpx;
}

.step-card {
  display: flex;
  gap: 18rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 58rpx;
  width: 58rpx;
  height: 58rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.step-body {
  flex: 1;
  min-width: 0;
}
