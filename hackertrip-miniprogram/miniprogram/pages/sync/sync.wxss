@import "../focus.wxss";

.sync-step-card {
  position: relative;
  margin: 24rpx 0;
  padding: 64rpx 24rpx 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.sync-step-card--yellow {
  background: #FBD902;
}

.step-badge {
  position: absolute;
  top: 16rpx;
  left: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  padding: 0 14rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.step-title {
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
}

.step-desc {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
}

.sync-code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  background: #F4F1E8;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
}

.sync-code-label {
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 900;
}

.sync-code-value {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.method-card {
  margin-top: 20rpx;
  padding: 18rpx;
  background: #F4F1E8;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
}

.method-card--agent {
  background: #FFFFFF;
}

.method-label {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  padding: 0 10rpx;
  color: #000000;
  background: #FBD902;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.method-title {
  margin-top: 12rpx;
  color: #000000;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.method-desc {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.4;
}

.command-text {
  max-height: 180rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  overflow-y: auto;
  color: #FFFFFF;
  background: #000000;
  border-radius: 10rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.action-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 72rpx;
  padding: 0 18rpx;
  margin: 22rpx 0 0;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-btn--primary {
  color: #FFFFFF;
  background: #0C51ED;
}

.action-btn--secondary {
  color: #000000;
  background: #FFFFFF;
}

.action-btn--disabled {
  color: #6F6C64;
  background: #D8D5CC;
}

.pair-input {
  height: 112rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
  text-align: center;
}

.sync-status {
  margin-top: 24rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.sync-result {
  margin-top: 28rpx;
}

.result-name {
  margin-top: 14rpx;
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.result-desc {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.result-chips {
  margin-top: 18rpx;
}

.result-meta {
  margin-top: 16rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
}
