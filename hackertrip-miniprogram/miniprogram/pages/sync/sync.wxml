<view class="focus-page sync-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">Skills 同步</view>
    <view class="focus-subtitle">输入桌面端生成的 6 位配对码，同步项目画像、技术栈和匹配结果。</view>

    <view class="brutal-box yellow-box">
      <view class="box-title">配对码</view>
      <input
        class="pair-input"
        value="{{code}}"
        type="number"
        maxlength="6"
        placeholder="000000"
        placeholder-class="placeholder-text"
        bindinput="onCodeInput"
      />
      <view class="sync-status">{{statusText}}</view>
      <button class="native-btn sync-btn" bindtap="syncNow">{{syncing ? '同步中...' : '同步 Skills'}}</button>
    </view>

    <view class="section-head">同步步骤</view>
    <view wx:for="{{steps}}" wx:key="title" class="list-card step-card">
      <view class="step-index">{{index + 1}}</view>
      <view class="step-body">
        <view class="list-title">{{item.title}}</view>
        <view class="list-subtitle">{{item.desc}}</view>
      </view>
    </view>

    <button wx:if="{{synced}}" class="native-btn native-btn--yellow" bindtap="goMatch">查看匹配结果</button>
  </view>
</view>
