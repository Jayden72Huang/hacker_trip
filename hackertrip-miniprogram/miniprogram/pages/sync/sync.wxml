<view class="focus-page sync-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">Skills 同步</view>
    <view class="focus-subtitle">先在小程序生成同步码，再选择 Agent 自动执行或 CLI 手动执行，最后回到这里拉取结果。</view>

    <view class="sync-step-card">
      <view class="step-badge">Step 1</view>
      <view class="step-title">生成同步码</view>
      <view class="step-desc">同步码绑定当前微信账号，30 分钟内有效。生成后再去电脑端执行。</view>
      <view class="sync-code-row">
        <view class="sync-code-label">当前同步码</view>
        <view class="sync-code-value">{{code || '未生成'}}</view>
      </view>
      <button class="native-btn action-btn action-btn--primary {{syncEndpointReady ? '' : 'action-btn--disabled'}}" bindtap="createPair">{{creating ? '生成中...' : '生成同步码'}}</button>
    </view>

    <view class="sync-step-card">
      <view class="step-badge">Step 2</view>
      <view class="step-title">电脑端执行</view>
      <view class="step-desc">推荐用 Agent 自动执行；如果不用 Agent，再复制 CLI 命令到项目根目录运行。</view>
      <view class="method-card method-card--agent">
        <view class="method-label">推荐方式</view>
        <view class="method-title">Agent / Skill 自动执行</view>
        <view class="method-desc">在 Claude Code、Codex、Cursor 等 Agent 里打开项目根目录，复制 Prompt 给它执行。</view>
        <button class="native-btn action-btn action-btn--primary {{commandReady ? '' : 'action-btn--disabled'}}" bindtap="copyAgentPrompt">复制 Agent Prompt</button>
      </view>
      <view class="method-card">
        <view class="method-label">备用方式</view>
        <view class="method-title">CLI 手动执行</view>
        <view class="method-desc">在项目根目录打开终端，复制下面命令直接运行，不需要改路径。</view>
        <view class="command-text">{{desktopCommand}}</view>
        <button class="native-btn action-btn action-btn--secondary {{commandReady ? '' : 'action-btn--disabled'}}" bindtap="copyCommand">复制 CLI 命令</button>
      </view>
    </view>

    <view class="sync-step-card sync-step-card--yellow">
      <view class="step-badge">Step 3</view>
      <view class="step-title">拉取结果</view>
      <view class="step-desc">电脑端提示推送完成后，回到这里点击按钮；同步后会更新推荐、身份卡和 Agent 上下文。</view>
      <input
        class="pair-input"
        value="{{code}}"
        type="number"
        maxlength="6"
        placeholder="000000"
        placeholder-class="placeholder-text"
        bindinput="onCodeInput"
      />
      <view class="sync-status">{{statusText}}</view>
      <button class="native-btn action-btn action-btn--primary sync-btn" bindtap="syncNow">{{syncing ? '拉取中...' : '拉取结果'}}</button>
    </view>

    <view wx:if="{{result}}" class="brutal-box sync-result">
      <view class="box-title">同步结果</view>
      <view class="result-name">{{result.project.name || '未命名项目'}}</view>
      <view class="result-desc">{{result.project.summary || result.project.description || '已同步项目画像和技术栈。'}}</view>
      <view class="chip-row result-chips">
        <text wx:for="{{resultSkills}}" wx:key="*this" class="focus-chip">{{item}}</text>
      </view>
      <view class="result-meta">匹配赛事 {{result.matches.length || 0}} 个 · 来源 {{result.source || 'HackerTrip CLI'}}</view>
    </view>

    <button wx:if="{{synced}}" class="native-btn native-btn--yellow" bindtap="goMatch">查看匹配结果</button>
  </view>
  <auth-modal id="authModal" bind:login="onAuthLogin" />
</view>
