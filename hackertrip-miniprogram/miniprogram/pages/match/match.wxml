<view class="focus-page match-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">赛事推荐</view>
    <view class="focus-subtitle">按你同步的项目技术栈推荐适合参加的黑客松，附推荐理由。</view>

    <!-- loading 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton">
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
        <view class="skeleton-line skeleton-line--short"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
      </view>
      <view class="skeleton-hint">正在匹配赛事…</view>
    </view>

    <block wx:elif="{{!hasProject}}">
    <view class="brutal-box">
      <view class="box-title">还没有项目画像</view>
      <view class="box-copy">同步一次 Skills，或和 Haki 聊聊你的项目方向，这里就会出现按你技术栈精准匹配的黑客松。</view>
      <button class="native-btn match-identity" bindtap="goSync">同步 Skills</button>
      <button class="native-btn native-btn--yellow match-identity" bindtap="goChat">问 Haki 推荐赛事</button>
    </view>
    </block>

    <block wx:else>
    <view class="brutal-box blue-box">
      <view class="box-title">项目卡</view>
      <view class="project-name">{{project.name}}</view>
      <view class="project-domain">{{project.domain}}</view>
      <view class="box-copy">{{project.summary}}</view>
      <view class="chip-row project-stack">
        <text wx:for="{{project.techStack}}" wx:key="*this" class="focus-chip focus-chip--yellow">{{item}}</text>
      </view>
    </view>

    <view class="section-head">Top {{matches.length}} 黑客松</view>
    <navigator
      wx:for="{{matches}}"
      wx:key="id"
      class="list-card match-card"
      url="/pages/detail/detail?id={{item.id}}"
      hover-class="list-card--active"
    >
      <view class="match-head">
        <text class="match-rank">#{{index + 1}}</text>
        <text class="list-title match-name">{{item.name}}</text>
        <text class="match-score">{{item.score}}%</text>
      </view>
      <view class="match-bar">
        <view class="match-fill" style="width: {{item.scoreWidth}};" />
      </view>
      <view class="list-subtitle">日期 {{item.dateText}} · 城市 {{item.cityText}} · 奖金 {{item.prizeText}}</view>
      <view class="list-subtitle">推荐赛道 {{item.tracksText}}</view>
      <view class="match-reason">{{item.reason}}</view>
    </navigator>

    <button class="native-btn native-btn--yellow match-identity" bindtap="makeCard">基于结果生成身份卡</button>
    </block>
  </view>
</view>
