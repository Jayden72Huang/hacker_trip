@import "../focus.wxss";

.form-field {
  margin-top: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.input-box,
.textarea-box {
  width: 100%;
  padding: 0 22rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.input-box {
  height: 86rpx;
}

.textarea-box {
  min-height: 180rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.mode-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.mode-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: #000000;
  background: #ECE8DB;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.mode-chip--active {
  color: #FFFFFF;
  background: #0C51ED;
}

.create-apply,
.create-submit {
  margin-top: 28rpx;
}
