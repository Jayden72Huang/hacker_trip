@import "../focus.wxss";

.form-field {
  margin-top: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.input-box,
.textarea-box {
  width: 100%;
  padding: 0 22rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.input-box {
  height: 86rpx;
}

.textarea-box {
  min-height: 180rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.mode-row {
  display: flex;
  gap: 12rpx;
}

.mode-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 0;
  width: 0;
  min-height: 72rpx;
  min-width: 0;
  padding: 0;
  box-sizing: border-box;
  color: #000000;
  background: #ECE8DB;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.mode-chip--active {
  color: #FFFFFF;
  background: #0C51ED;
}

.create-apply,
.create-submit {
  margin-top: 28rpx;
}

.submit-pair-card {
  background: #FFFFFF;
}

.submit-pair-btn {
  margin-top: 24rpx;
}

.pair-result {
  margin-top: 28rpx;
}

.pair-code {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 116rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 58rpx;
  font-weight: 900;
  letter-spacing: 14rpx;
  line-height: 1;
}

.pair-meta,
.pair-status {
  margin-top: 22rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.pair-token-label {
  margin-top: 24rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.pair-token {
  margin-top: 10rpx;
  padding: 18rpx;
  color: #FFFFFF;
  background: #000000;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.45;
  word-break: break-all;
}

.pair-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.pair-copy {
  min-height: 74rpx;
  margin: 0;
  font-size: 23rpx;
}
