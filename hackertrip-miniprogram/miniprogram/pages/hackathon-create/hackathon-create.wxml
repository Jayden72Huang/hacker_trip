<view class="focus-page create-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">发布黑客松</view>
    <view class="focus-subtitle">提交后先进入审核，审核通过后才会展示给参赛者和微信 AI。</view>

    <view wx:if="{{!allowed}}" class="brutal-box yellow-box">
      <view class="box-title">需要组织者认证</view>
      <view class="box-copy">发布黑客松前，需要先申请成为组织者并通过审核。</view>
      <button class="native-btn create-apply" bindtap="goApply">申请成为组织者</button>
    </view>

    <block wx:else>
      <view class="submit-tabs">
        <button class="submit-tab {{submitMode === 'manual' ? 'submit-tab--active' : ''}}" data-mode="manual" bindtap="switchSubmitMode">人工填写提交</button>
        <button class="submit-tab {{submitMode === 'agent' ? 'submit-tab--active' : ''}}" data-mode="agent" bindtap="switchSubmitMode">让 AI 帮我提交</button>
      </view>

      <view wx:if="{{submitMode === 'agent'}}" class="brutal-box submit-pair-card">
        <view class="box-title">让 AI 帮我提交</view>
        <view class="box-copy">不想一栏一栏手动填表？把海报或官网丢给 AI，让它整理成一份赛事资料，跟着下面四步、三次复制粘贴就能提交，平台审核后上架。</view>
        <view class="agent-submit-steps">
          <view class="agent-submit-step">
            <view class="agent-step-index">1</view>
            <view class="agent-step-body">
              <view class="agent-step-title">在电脑上装好提交小工具</view>
              <view class="agent-step-copy">打开电脑上的终端，把下面的命令粘贴进去回车，装好 hackertrip 这个提交小工具。不熟悉终端也没关系，可以让 Claude、Codex 这类 AI 助手替你跑。</view>
              <view class="agent-step-command">
                <view>npx hackertrip --help</view>
                <view>npm i -g hackertrip</view>
              </view>
              <button class="native-btn agent-step-btn" bindtap="copyCliCommand">复制安装命令</button>
            </view>
          </view>
          <view class="agent-submit-step">
            <view class="agent-step-index">2</view>
            <view class="agent-step-body">
              <view class="agent-step-title">让 AI 把赛事整理成一份资料文件</view>
              <view class="agent-step-copy">把官网链接、海报或活动说明发给 Claude、Codex、Cursor 这类 AI 助手，让它照下面的模板整理成一份赛事资料文件（event.json）。你也可以照着模板自己填。</view>
              <view class="agent-step-command">
                <view>{ "name": "赛事名称",</view>
                <view>  "city": "城市 / 线上",</view>
                <view>  "startDate": "YYYY-MM-DD",</view>
                <view>  "website": "https://" }</view>
              </view>
              <button class="native-btn agent-step-btn" bindtap="copyEventJsonTemplate">复制赛事资料模板</button>
            </view>
          </view>
          <view class="agent-submit-step">
            <view class="agent-step-index">3</view>
            <view class="agent-step-body">
              <view class="agent-step-title">点一下，拿到 6 位提交码</view>
              <view class="agent-step-copy">点下面的按钮，拿到一个 6 位提交码和一把提交密钥，就像取件码，只用于这一次提交，30 分钟内有效。</view>
              <button
                class="native-btn agent-step-btn"
                bindtap="createSubmitPair"
                loading="{{pairCreating}}"
                disabled="{{pairCreating}}"
              >{{pairCreating ? '生成中...' : '生成提交码'}}</button>
            </view>
          </view>
          <view class="agent-submit-step">
            <view class="agent-step-index">4</view>
            <view class="agent-step-body">
              <view class="agent-step-title">回电脑粘贴命令，提交完成</view>
              <view class="agent-step-copy">把下面的命令复制到电脑终端回车，提交就完成了，之后平台审核通过就会上架。命令里已自动填好你的提交码和密钥。</view>
              <view class="agent-step-command">
                <view>npx hackertrip submit-event \</view>
                <view>  --pair-code {{pairCode || 'PAIR_CODE'}} \</view>
                <view>  --sync-token {{pairUploadToken || 'UPLOAD_TOKEN'}} \</view>
                <view>  --from event.json</view>
              </view>
              <button class="native-btn agent-step-btn" bindtap="copySubmitCommand">复制提交命令</button>
            </view>
          </view>
        </view>

        <view wx:if="{{pairCode}}" class="pair-result">
          <view class="pair-code">{{pairCode}}</view>
          <view class="pair-meta">有效期 {{pairExpireText || '30 分钟'}} · {{pairCountdown}}</view>
          <view class="pair-token-label">提交密钥</view>
          <view class="pair-token">{{pairUploadToken}}</view>
          <view class="pair-actions">
            <button class="native-btn pair-copy" bindtap="copyPairCode">复制提交码</button>
            <button class="native-btn native-btn--yellow pair-copy" bindtap="copyPairToken">复制密钥</button>
          </view>
        </view>
        <view wx:else class="pair-status">{{pairStatusText}}</view>
      </view>

      <view wx:if="{{submitMode === 'manual'}}" class="brutal-box">
      <view class="box-title">人工填写提交赛事信息</view>
      <view class="box-copy">默认提交方式。填写基础信息后进入平台审核，审核通过才会展示给参赛者。</view>
      <view class="form-field">
        <view class="field-label">赛事名称</view>
        <input class="input-box" value="{{form.name}}" data-field="name" placeholder="例如 AI Agent 黑客松" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">城市</view>
        <input class="input-box" value="{{form.city}}" data-field="city" placeholder="深圳 / 上海 / 线上" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">举办形式</view>
        <view class="mode-row">
          <button class="mode-chip {{form.mode === 'offline' ? 'mode-chip--active' : ''}}" data-mode="offline" bindtap="chooseMode">线下</button>
          <button class="mode-chip {{form.mode === 'online' ? 'mode-chip--active' : ''}}" data-mode="online" bindtap="chooseMode">线上</button>
          <button class="mode-chip {{form.mode === 'hybrid' ? 'mode-chip--active' : ''}}" data-mode="hybrid" bindtap="chooseMode">混合</button>
        </view>
      </view>
      <view class="form-grid">
        <view class="form-field">
          <view class="field-label">开始日期</view>
          <input class="input-box" value="{{form.startDate}}" data-field="startDate" placeholder="YYYY-MM-DD" bindinput="onFieldInput" />
        </view>
        <view class="form-field">
          <view class="field-label">结束日期</view>
          <input class="input-box" value="{{form.endDate}}" data-field="endDate" placeholder="YYYY-MM-DD" bindinput="onFieldInput" />
        </view>
      </view>
      <view class="form-field">
        <view class="field-label">奖金 / 资源</view>
        <input class="input-box" value="{{form.prizePool}}" data-field="prizePool" placeholder="例如 10万元奖金 + 云资源" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">赛道 / 技术方向</view>
        <input class="input-box" value="{{form.tracks}}" data-field="tracks" placeholder="AI Agent、Web3、硬件..." bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">官网 / 报名链接</view>
        <input class="input-box" value="{{form.website}}" data-field="website" placeholder="https://" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">一句话简介</view>
        <textarea class="textarea-box" value="{{form.summary}}" data-field="summary" placeholder="说明活动主题、参赛对象、亮点和报名要求。" bindinput="onFieldInput" />
      </view>
      <button
        class="native-btn native-btn--yellow create-submit"
        bindtap="submitHackathon"
        loading="{{submitting}}"
        disabled="{{submitting}}"
      >{{submitting ? '安全检测中' : '提交审核'}}</button>
      </view>
    </block>
  </view>
  <auth-modal id="authModal" bind:login="onAuthLogin" />
</view>
