<view class="focus-page organizer-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">组织者认证</view>
    <view class="focus-subtitle">通过认证后，可以发布黑客松并管理赛事信息。</view>

    <view class="brutal-box yellow-box organizer-state">
      <view>
        <view class="box-title">当前状态</view>
        <view class="state-copy">{{statusText}}</view>
        <view class="state-hint">{{statusHint}}</view>
      </view>
      <button class="status-action {{status === 'approved' ? 'status-action--approved' : ''}}" bindtap="onStatusAction">{{statusActionText}}</button>
    </view>

    <view wx:if="{{claimEventId}}" class="brutal-box claim-box">
      <view class="box-title">认领赛事</view>
      <view class="claim-event-name">{{claimEvent.name || '正在读取赛事信息'}}</view>
      <view class="claim-event-meta">{{claimEvent.cityText || claimEvent.city || '城市待确认'}} · {{claimEvent.dateText || '时间待确认'}}</view>
      <view class="claim-status-row">
        <text class="claim-status {{claimStatus === 'approved' ? 'claim-status--approved' : ''}} {{claimStatus === 'rejected' ? 'claim-status--rejected' : ''}}">{{claimStatusText}}</text>
      </view>
      <view class="claim-hint">{{claimStatusHint}}</view>

      <view wx:if="{{status === 'approved' && (claimStatus === 'none' || claimStatus === 'rejected')}}" class="claim-form">
        <view class="form-field">
          <view class="field-label">你和这场赛事的关系</view>
          <input class="input-box" value="{{claimForm.claimRole}}" data-field="claimRole" placeholder="例如主办方负责人 / 联合主办 / 执行团队" bindinput="onClaimFieldInput" />
        </view>
        <view class="form-field">
          <view class="field-label">认领联系方式</view>
          <input class="input-box" value="{{claimForm.contact}}" data-field="contact" placeholder="微信 / 邮箱 / 手机" bindinput="onClaimFieldInput" />
        </view>
        <view class="form-field">
          <view class="field-label">证明链接</view>
          <input class="input-box" value="{{claimForm.proofUrl}}" data-field="proofUrl" placeholder="官网、公众号文章、活动页或主办方页面" bindinput="onClaimFieldInput" />
        </view>
        <view class="form-field">
          <view class="field-label">认领说明</view>
          <textarea class="textarea-box" value="{{claimForm.note}}" data-field="note" placeholder="说明你为什么能认领这场赛事，例如负责报名、运营、赞助或主办。" bindinput="onClaimFieldInput" />
        </view>
      </view>

      <button
        class="native-btn claim-submit {{claimStatus === 'approved' ? 'native-btn--yellow' : ''}}"
        bindtap="submitClaim"
        loading="{{claimSubmitting}}"
        disabled="{{claimSubmitting || claimStatus === 'pending' || claimStatus === 'security_review'}}"
      >{{claimSubmitting ? '提交中' : claimActionText}}</button>
    </view>

    <view wx:if="{{status !== 'pending' && status !== 'approved'}}" id="organizer-form" class="brutal-box">
      <view class="box-title">申请信息</view>
      <view class="form-field">
        <view class="field-label">机构 / 团队名称</view>
        <input class="input-box" value="{{form.orgName}}" data-field="orgName" placeholder="例如 HackerTrip / 某大学社团" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">你的身份</view>
        <input class="input-box" value="{{form.role}}" data-field="role" placeholder="主办方、社区负责人、赞助方..." bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">联系方式</view>
        <input class="input-box" value="{{form.contact}}" data-field="contact" placeholder="微信 / 邮箱 / 手机" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">官网或活动链接</view>
        <input class="input-box" value="{{form.website}}" data-field="website" placeholder="https://" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <view class="field-label">补充说明</view>
        <textarea class="textarea-box" value="{{form.note}}" data-field="note" placeholder="说明你要举办的黑客松类型、城市、规模。" bindinput="onFieldInput" />
      </view>
      <button
        class="native-btn native-btn--yellow organizer-submit"
        bindtap="submitApplication"
        loading="{{submitting}}"
        disabled="{{submitting}}"
      >{{submitting ? '安全检测中' : '提交组织者申请'}}</button>
    </view>

    <view wx:if="{{ownedHackathons.length}}" class="section-head">已认领赛事</view>
    <view wx:for="{{ownedHackathons}}" wx:key="id" class="list-card owned-card">
      <view class="list-title">{{item.name}}</view>
      <view class="list-subtitle">{{item.cityText}} · {{item.dateText}}</view>
      <view class="owned-actions">
        <button class="owned-btn owned-btn--white" data-id="{{item.id}}" bindtap="goOwnedDetail">赛事详情</button>
      </view>
    </view>

    <view wx:if="{{claims.length}}" class="section-head">认领申请</view>
    <view wx:for="{{claims}}" wx:key="eventId" class="list-card">
      <view class="list-title">{{item.eventName}}</view>
      <view class="list-subtitle">{{item.statusText}} · {{item.eventCity || '城市待确认'}}</view>
    </view>

    <view class="section-head">已提交赛事</view>
    <view wx:if="{{drafts.length === 0}}" class="list-card empty-draft">
      <view class="list-title">暂无赛事草稿</view>
      <view class="list-subtitle">认证通过后，可以提交第一场黑客松。</view>
    </view>
    <view wx:for="{{drafts}}" wx:key="id" class="list-card">
      <view class="list-title">{{item.name}}</view>
      <view class="list-subtitle">{{item.city}} · {{item.startDate}} - {{item.endDate}} · {{item.statusText}}</view>
    </view>

    <view class="tutorial-card">
      <view class="tutorial-head" bindtap="toggleTutorial">
        <view class="tutorial-head-title">💻 终端里怎么提交赛事</view>
        <view class="tutorial-arrow {{tutorialOpen ? 'tutorial-arrow--open' : ''}}">⌄</view>
      </view>
      <view wx:if="{{tutorialOpen}}" class="tutorial-body">
        <view class="tutorial-step">
          <view class="tutorial-step-title">1. 安装 CLI</view>
          <view class="tutorial-cmd-row">
            <scroll-view scroll-x class="tutorial-cmd">npm i -g hackertrip</scroll-view>
            <view class="tutorial-copy" data-cmd="npm i -g hackertrip" bindtap="copyTutorialCmd">复制</view>
          </view>
        </view>
        <view class="tutorial-step">
          <view class="tutorial-step-title">2. 生成提交码</view>
          <view class="tutorial-step-desc">在本页生成提交码，绑定你的组织者账号后再回终端使用。</view>
        </view>
        <view class="tutorial-step">
          <view class="tutorial-step-title">3. 提交赛事</view>
          <view class="tutorial-cmd-row">
            <scroll-view scroll-x class="tutorial-cmd">hackertrip submit-event --pair-code 你的提交码 --name "赛事名" --city "城市" --start 2026-08-01 --end 2026-08-03 --website "https://..."</scroll-view>
            <view class="tutorial-copy" data-cmd='hackertrip submit-event --pair-code 你的提交码 --name "赛事名" --city "城市" --start 2026-08-01 --end 2026-08-03 --website "https://..."' bindtap="copyTutorialCmd">复制</view>
          </view>
        </view>
        <view class="tutorial-agent-note">
          <view class="tutorial-agent-text">也可以装好 Skills 后，把海报图丢给 Claude 说「帮我把这个黑客松发到 HackerTrip」。</view>
          <view class="tutorial-cmd-row">
            <scroll-view scroll-x class="tutorial-cmd">npx hackertrip install-skills --organizer</scroll-view>
            <view class="tutorial-copy" data-cmd="npx hackertrip install-skills --organizer" bindtap="copyTutorialCmd">复制</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <auth-modal id="authModal" bind:login="onAuthLogin" />
</view>
