@import "../focus.wxss";

.chat-page {
  padding-bottom: 190rpx;
}

.chat-thread {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.bubble {
  max-width: 88%;
  padding: 22rpx 24rpx;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
}

.bubble--assistant {
  align-self: flex-start;
  color: #000000;
  background: #FFFFFF;
}

.bubble--user {
  align-self: flex-end;
  color: #FFFFFF;
  background: #0C51ED;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.quick-chip {
  min-height: 58rpx;
  padding: 0 20rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
}

.chat-inputbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 70;
  display: flex;
  gap: 14rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 4rpx solid #000000;
  box-shadow: 0 -6rpx 0 0 #000000;
}

.chat-input {
  flex: 1;
  height: 82rpx;
  padding: 0 22rpx;
  color: #000000;
  background: #F4F1E8;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.send-btn {
  width: 132rpx;
  height: 82rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 26rpx;
  font-weight: 900;
}

/* 推荐赛事 — 紧凑小卡片，不占大篇幅 */
.rec-mini {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}
.rec-mini--active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}
.rec-mini-label {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  color: #000000;
  background: #FBD902;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.rec-mini-body {
  flex: 1;
  min-width: 0;
}
.rec-mini-name {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 25rpx;
  font-weight: 900;
  color: #000000;
}
.rec-mini-meta {
  margin-top: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 21rpx;
  color: #5A5A55;
}
.rec-mini-arrow {
  flex-shrink: 0;
  color: #0C51ED;
  font-size: 38rpx;
  font-weight: 900;
}

/* 快捷回复 chip 防微信 button 撑满 */
.quick-chip {
  display: inline-flex !important;
  align-items: center;
  width: auto !important;
  line-height: 1.2;
}
.quick-chip::after {
  border: none;
}

/* 流式打字光标闪烁 */
.bubble-caret {
  animation: caret-blink 0.9s steps(1) infinite;
}
@keyframes caret-blink {
  50% { opacity: 0; }
}
