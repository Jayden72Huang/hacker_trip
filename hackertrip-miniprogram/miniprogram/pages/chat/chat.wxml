<view class="focus-page chat-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content chat-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">Haki 聊天</view>
    <view class="focus-subtitle">对话里保留赛事名称、时间、城市、奖金和赛道，便于微信 AI 理解页面内容。</view>

    <view class="chat-thread">
      <view wx:for="{{messages}}" wx:key="index" class="bubble bubble--{{item.role}}">
        <text>{{item.pending && !item.text ? '思考中…' : item.text}}</text>
        <text wx:if="{{item.pending && item.text}}" class="bubble-caret">▍</text>
      </view>
    </view>

    <!-- 推荐赛事：紧凑小卡片，不占大篇幅 -->
    <navigator wx:if="{{event}}" class="rec-mini" url="/pages/detail/detail?id={{event.id}}" hover-class="rec-mini--active">
      <text class="rec-mini-label">荐</text>
      <view class="rec-mini-body">
        <view class="rec-mini-name">{{event.shortName || event.name}}</view>
        <view class="rec-mini-meta">{{event.city}} · {{event.modeText}}{{event.prizePool ? ' · ' + event.prizePool : ''}}</view>
      </view>
      <text class="rec-mini-arrow">›</text>
    </navigator>

    <!-- 快捷回复：仅开场(还没真正对话)时显示，发送后隐藏，不常驻 -->
    <view wx:if="{{messages.length <= 1}}" class="quick-row">
      <button
        wx:for="{{quickReplies}}"
        wx:key="*this"
        class="quick-chip"
        data-text="{{item}}"
        bindtap="useQuickReply"
      >{{item}}</button>
    </view>
  </view>

  <view class="chat-inputbar">
    <input
      class="chat-input"
      value="{{inputValue}}"
      placeholder="输入项目方向或技术栈"
      placeholder-class="placeholder-text"
      confirm-type="send"
      bindinput="onInput"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage" disabled="{{sending}}">{{sending ? '…' : '发送'}}</button>
  </view>
</view>
