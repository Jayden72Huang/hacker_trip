<view class="page page--tab inbox-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="page-title">消息</view>
    <view class="page-subtitle">报名与收藏赛事的截止提醒、系统通知集中在这里。</view>

    <navigator
      class="haki-entry"
      url="/pages/chat/chat?intent=inbox.assistant"
      hover-class="haki-entry--active"
    >
      <view class="haki-entry-mark">AI</view>
      <view class="haki-entry-body">
        <view class="haki-entry-title">Haki 助手</view>
        <view class="haki-entry-sub">把项目方向、技术栈和城市偏好发给 Haki，快速判断适合参加哪些黑客松。</view>
      </view>
      <view class="haki-entry-cta">去问</view>
    </navigator>

    <view class="subscribe-card">
      <view class="subscribe-copy">
        <view class="subscribe-title">订阅黑客松提醒</view>
        <view class="subscribe-text">上新、智能推荐和报名截止提醒会集中发送到这里。</view>
      </view>
      <button class="subscribe-btn" bindtap="subscribeHackathonMessages">开启提醒</button>
    </view>

    <!-- loading 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton">
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-line--title"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
      </view>
      <view class="skeleton-hint">加载中…</view>
    </view>

    <block wx:else>
      <view wx:for="{{groups}}" wx:key="key" class="message-section">
        <view class="section-title">{{item.title}}</view>
        <view wx:if="{{item.empty && item.items.length === 0}}" class="message-empty">{{item.empty}}</view>
        <navigator
          wx:for="{{item.items}}"
          wx:for-item="msg"
          wx:key="title"
          class="message-card message-card--{{msg.level}}"
          url="{{msg.url}}"
          hover-class="message-card--active"
        >
          <view class="message-tag">{{msg.tag}}</view>
          <view class="message-body">
            <view class="message-title">{{msg.title}}</view>
            <view class="message-sub">{{msg.sub}}</view>
          </view>
          <text class="message-time">{{msg.time}}</text>
        </navigator>
      </view>
    </block>
  </view>
  <auth-modal id="authModal" />
</view>
