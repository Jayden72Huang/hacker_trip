.inbox-page {
  padding-bottom: 210rpx;
}

.message-section {
  margin-bottom: 34rpx;
}

.message-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-height: 138rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.message-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.message-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  max-width: 120rpx;
  min-height: 58rpx;
  padding: 8rpx 10rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  flex-shrink: 0;
}

.message-card--urgent .message-tag {
  color: #FFFFFF;
  background: #FF4D2E;
}

.message-card--match .message-tag {
  color: #FFFFFF;
  background: #0C51ED;
}

.message-card--system .message-tag {
  color: #000000;
  background: #FBD902;
}

.message-body {
  flex: 1;
  min-width: 0;
}

.message-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.message-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.message-time {
  color: #7A7A75;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.message-empty {
  padding: 32rpx 24rpx;
  color: #7A7A75;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}
