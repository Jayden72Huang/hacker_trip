.inbox-page {
  padding-bottom: 210rpx;
}

.message-section {
  margin-bottom: 34rpx;
}

.haki-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  margin: 8rpx 0 32rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.haki-entry--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.haki-entry-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.haki-entry-body {
  flex: 1;
  min-width: 0;
}

.haki-entry-title {
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.haki-entry-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.haki-entry-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 82rpx;
  height: 56rpx;
  padding: 0 16rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 23rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.subscribe-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 0 0 32rpx;
  padding: 22rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.subscribe-copy {
  flex: 1;
  min-width: 0;
}

.subscribe-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.subscribe-text {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.subscribe-btn {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: auto !important;
  height: 62rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.subscribe-btn::after {
  border: none;
}

.subscribe-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.message-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-height: 138rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.message-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.message-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  max-width: 120rpx;
  min-height: 58rpx;
  padding: 8rpx 10rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  flex-shrink: 0;
}

.message-card--urgent .message-tag {
  color: #FFFFFF;
  background: #FF4D2E;
}

.message-card--match .message-tag {
  color: #FFFFFF;
  background: #0C51ED;
}

.message-card--system .message-tag {
  color: #000000;
  background: #FBD902;
}

.message-body {
  flex: 1;
  min-width: 0;
}

.message-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.message-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.message-time {
  color: #7A7A75;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.message-empty {
  padding: 32rpx 24rpx;
  color: #7A7A75;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}
