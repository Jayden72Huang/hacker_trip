.profile-page {
  padding-bottom: 210rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 52rpx;
  font-weight: 900;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-copy .page-title {
  margin-top: 0;
}

.identity-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
  margin-top: 26rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 10rpx 10rpx 0 0 #000000;
}

.identity-entry--active {
  transform: translate(5rpx, 5rpx);
  box-shadow: 5rpx 5rpx 0 0 #000000;
}

.identity-kicker {
  display: inline-flex;
  padding: 6rpx 12rpx;
  color: #FFFFFF;
  background: #000000;
  border: 2rpx solid #000000;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.identity-title {
  margin-top: 16rpx;
  color: #000000;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
}

.identity-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.identity-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.asset-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.asset-card {
  min-height: 132rpx;
  padding: 20rpx 12rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  text-align: center;
}

.asset-value {
  color: #0C51ED;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.asset-label {
  margin-top: 16rpx;
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.link-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-tabs {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  margin: 22rpx 0 24rpx;
  padding: 0;
}

.role-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 0;
  min-width: 0;
  min-height: 74rpx;
  color: #000000;
  background: #ECE8DB;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.role-tab + .role-tab {
  margin-left: 14rpx;
}

.role-tab--participant {
  color: #FFFFFF;
  background: #0C51ED;
}

.role-tab--organizer {
  color: #000000;
  background: #FBD902;
}

.role-section-title {
  margin-top: 36rpx;
}

.role-empty {
  margin-top: 0;
}

.organizer-status {
  padding: 24rpx;
  margin-top: 22rpx;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.organizer-status-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.organizer-status-label {
  color: #000000;
  font-size: 28rpx;
  font-weight: 900;
}

.organizer-status-value {
  padding: 8rpx 16rpx;
  color: #FFFFFF;
  background: #000000;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.organizer-status-value.is-approved {
  color: #000000;
  background: #13B36B;
}

.organizer-status-copy {
  margin-top: 12rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.link-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.link-card--disabled {
  opacity: 0.52;
  background: #ECE8DB;
}

.link-card--organizer {
  border-color: #000000;
}

.link-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.link-main {
  flex: 1;
  min-width: 0;
}

.link-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.link-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.link-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 78rpx;
  height: 54rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.link-arrow--disabled {
  color: #3D3D3D;
  background: #ECE8DB;
}

.link-arrow--organizer {
  color: #000000;
  background: #FBD902;
}

/* ---------------- 个人资料卡 ---------------- */
.profile-card {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 30rpx;
  margin-top: 0;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

/* 上层：头像 + 资料 + 编辑按钮 */
.profile-head {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

/* 下层：卡内数据指标行 */
.profile-stats {
  display: flex;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 4rpx dashed #000000;
}

.profile-stat {
  flex: 1;
  text-align: center;
}

/* 指标之间的竖向分隔线 */
.profile-stat + .profile-stat {
  border-left: 3rpx solid rgba(0, 0, 0, 0.12);
}

.profile-stat-value {
  color: #0C51ED;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
}

.profile-stat-label {
  margin-top: 14rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

/* 未填写(黄底)时指标文字配色调整，保证对比 */
.profile-card--empty .profile-stat-value {
  color: #000000;
}

/* 已填写：白底专业卡(skills 蓝色高亮) */
.profile-card--filled {
  background: #FFFFFF;
}

/* 未填写：黄底醒目引导 */
.profile-card--empty {
  background: #FBD902;
}

.profile-card--organizer.profile-card--filled {
  background: #FBD902;
}

.profile-card--organizer .profile-stat-value,
.profile-card--organizer .profile-skills {
  color: #000000;
}

.profile-card--organizer .profile-edit-btn {
  color: #000000;
  background: #FBD902;
}

.profile-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.profile-name {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

/* 头像按钮（open-type=chooseAvatar）：清掉 button 默认样式，沿用 .avatar 外观 */
.avatar-btn {
  /* 微信 button 默认 width:184px 优先级高，必须 !important 压制 */
  width: 108rpx !important;
  min-width: 0;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.avatar-btn::after {
  border: none;
}

/* 昵称输入框（type=nickname）：外观与 profile-name 一致，可直接编辑 */
.profile-name-input {
  width: 100%;
  height: 48rpx;
  min-height: 48rpx;
  line-height: 48rpx;
  padding: 0;
  background: transparent;
  border: none;
}

.profile-name-placeholder {
  color: rgba(0, 0, 0, 0.35);
  font-weight: 900;
}

.profile-meta {
  margin-top: 6rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.profile-skills {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-top: 8rpx;
  color: #0C51ED;
  font-size: 23rpx;
  font-weight: 900;
}

.profile-edit-btn {
  flex-shrink: 0;
  min-width: 82rpx;
  padding: 12rpx 18rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}
