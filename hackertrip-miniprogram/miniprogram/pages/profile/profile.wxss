.profile-page {
  padding-bottom: 210rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 52rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-copy .page-title {
  margin-top: 0;
}

.identity-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
  margin-top: 26rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 10rpx 10rpx 0 0 #000000;
}

.identity-entry--active {
  transform: translate(5rpx, 5rpx);
  box-shadow: 5rpx 5rpx 0 0 #000000;
}

.identity-kicker {
  display: inline-flex;
  padding: 6rpx 12rpx;
  color: #FFFFFF;
  background: #000000;
  border: 2rpx solid #000000;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.identity-title {
  margin-top: 16rpx;
  color: #000000;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
}

.identity-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.identity-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.asset-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.asset-card {
  min-height: 132rpx;
  padding: 20rpx 12rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  text-align: center;
}

.asset-value {
  color: #0C51ED;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.asset-label {
  margin-top: 16rpx;
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.link-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.link-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.link-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.link-main {
  flex: 1;
  min-width: 0;
}

.link-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.link-sub {
  margin-top: 8rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.link-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 78rpx;
  height: 54rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}
