<view class="page page--tab profile-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="page-title">我的</view>

    <!-- 个人资料卡：上层资料 + 下层黑客松数据指标。点击进入编辑 -->
    <navigator
      class="profile-card {{profileCard.filled ? 'profile-card--filled' : 'profile-card--empty'}}"
      url="/pages/identity-edit/identity-edit"
      hover-class="profile-card--active"
    >
      <view class="profile-head">
        <view class="avatar">{{profileCard.avatarChar}}</view>
        <view class="profile-copy">
          <block wx:if="{{profileCard.filled}}">
            <view class="profile-name">{{profileCard.nickname}}</view>
            <view class="profile-meta">{{profileCard.role}}{{profileCard.city ? ' · ' + profileCard.city : ''}}</view>
            <view wx:if="{{profileCard.skillsText}}" class="profile-skills">{{profileCard.skillsText}}</view>
          </block>
          <block wx:else>
            <view class="profile-name">完善个人资料</view>
            <view class="profile-meta">填写昵称、角色、城市和技能，匹配更精准</view>
          </block>
        </view>
        <view class="profile-edit-btn">{{profileCard.filled ? '编辑' : '去填写'}}</view>
      </view>

      <!-- 卡内数据指标行 -->
      <view class="profile-stats">
        <view wx:for="{{assetStats}}" wx:key="label" class="profile-stat">
          <view class="profile-stat-value">{{item.value}}</view>
          <view class="profile-stat-label">{{item.label}}</view>
        </view>
      </view>
    </navigator>

    <!-- 收藏为 0 时的引导空态 -->
    <view wx:if="{{!loading && savedCount === 0}}" class="empty-state" style="margin-top: 20rpx;">
      <view class="empty-state-title">还没有关注的赛事</view>
      <view class="empty-state-text">去发现页收藏感兴趣的黑客松，资产会自动汇总到这里。</view>
      <navigator class="empty-cta" url="/pages/index/index" open-type="switchTab" hover-class="empty-cta--active">去发现页逛逛</navigator>
    </view>

    <view class="section-title">工具</view>
    <view class="link-list">
      <navigator
        wx:for="{{tools}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">打开</text>
      </navigator>
    </view>

    <view class="section-title">设置</view>
    <view class="link-list">
      <navigator
        wx:for="{{settings}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">进入</text>
      </navigator>
    </view>
  </view>
</view>
