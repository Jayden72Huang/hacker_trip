<view class="page page--tab profile-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="profile-head">
      <view class="avatar">{{avatarChar}}</view>
      <view class="profile-copy">
        <view class="page-title">我的</view>
        <view class="page-subtitle">管理身份卡、参赛资产和工具配置。</view>
      </view>
    </view>

    <navigator class="identity-entry" url="/pages/identity/identity" hover-class="identity-entry--active">
      <view>
        <view class="identity-kicker">Identity Card</view>
        <view class="identity-title">生成开发者身份卡</view>
        <view class="identity-sub">展示技术栈、参赛方向和可合作角色。</view>
      </view>
      <view class="identity-arrow">→</view>
    </navigator>

    <view class="section-title">参赛资产</view>
    <view class="asset-grid">
      <view wx:for="{{assetStats}}" wx:key="label" class="asset-card">
        <view class="asset-value">{{item.value}}</view>
        <view class="asset-label">{{item.label}}</view>
      </view>
    </view>

    <view class="section-title">工具</view>
    <view class="link-list">
      <navigator
        wx:for="{{tools}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">打开</text>
      </navigator>
    </view>

    <view class="section-title">设置</view>
    <view class="link-list">
      <navigator
        wx:for="{{settings}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">进入</text>
      </navigator>
    </view>
  </view>
</view>
