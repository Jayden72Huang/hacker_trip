<view class="page page--tab profile-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="page-title">我的</view>

    <view class="role-tabs" aria-label="身份选择">
      <button
        class="role-tab {{profileMode === 'participant' ? 'role-tab--participant' : ''}}"
        data-mode="participant"
        bindtap="switchMode"
      >我要参赛</button>
      <button
        class="role-tab {{profileMode === 'organizer' ? 'role-tab--organizer' : ''}}"
        data-mode="organizer"
        bindtap="switchMode"
      >我要举办</button>
    </view>

    <!-- 个人资料卡：上层资料 + 下层黑客松数据指标。点击进入编辑 -->
    <navigator
      class="profile-card {{profileCard.filled ? 'profile-card--filled' : 'profile-card--empty'}} {{profileMode === 'organizer' ? 'profile-card--organizer' : ''}}"
      url="/pages/identity-edit/identity-edit"
      hover-class="profile-card--active"
    >
      <view class="profile-head">
        <!-- 微信头像昵称填写能力：点头像唤起微信头像选择，点昵称可用微信昵称快捷填入 -->
        <button class="avatar avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" catchtap="noop">
          <image wx:if="{{profileCard.avatarUrl}}" class="avatar-image" src="{{profileCard.avatarUrl}}" mode="aspectFill" />
          <text wx:else>{{profileCard.avatarChar}}</text>
        </button>
        <view class="profile-copy">
          <input
            class="profile-name profile-name-input"
            type="nickname"
            value="{{profileCard.nickname}}"
            placeholder="热爱黑客松的你"
            placeholder-class="profile-name-placeholder"
            catchtap="noop"
            bindblur="onNicknameChange"
            bindconfirm="onNicknameChange"
          />
          <block wx:if="{{profileCard.filled}}">
            <view class="profile-meta">{{profileCard.role}}{{profileCard.city ? ' · ' + profileCard.city : ''}}</view>
            <view wx:if="{{profileCard.skillsText}}" class="profile-skills">{{profileCard.skillsText}}</view>
          </block>
          <view wx:else class="profile-meta">点头像和昵称直接用微信资料，角色和技能点右侧填写</view>
        </view>
        <view class="profile-edit-btn">{{profileCard.filled ? '编辑' : '去填写'}}</view>
      </view>

      <!-- 卡内数据指标行：点击跳转对应页面补数据 -->
      <view class="profile-stats">
        <view wx:for="{{assetStats}}" wx:key="label" class="profile-stat" data-url="{{item.url}}" catchtap="onStatTap">
          <view class="profile-stat-value">{{item.value}}</view>
          <view class="profile-stat-label">{{item.label}}</view>
        </view>
      </view>
    </navigator>

    <view wx:if="{{profileMode === 'organizer'}}" class="organizer-status" bindtap="goOrganizerStatus" hover-class="none">
      <view class="organizer-status-main">
        <text class="organizer-status-label">组织者状态</text>
        <text class="organizer-status-value {{organizerStatus === 'approved' ? 'is-approved' : ''}}">{{organizerStatusText}}</text>
      </view>
      <view class="organizer-status-copy">{{organizerStatus === 'approved' ? '已获得组织者权益，点击查看认证详情和权益功能。' : '通过组织者认证后，可以发布黑客松并管理赛事信息。点击去认证。'}}</view>
    </view>

    <view class="section-title role-section-title">{{profileMode === 'organizer' ? '举办方工具' : '工具'}}</view>
    <view wx:if="{{profileMode === 'participant'}}" class="link-list">
      <navigator
        wx:for="{{tools}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">打开</text>
      </navigator>
    </view>
    <view wx:else class="link-list">
      <view
        wx:for="{{organizerTools}}"
        wx:key="title"
        class="link-card link-card--organizer {{item.action === 'disabled' ? 'link-card--disabled' : ''}}"
        data-index="{{index}}"
        bindtap="onOrganizerToolTap"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow link-arrow--organizer {{item.action === 'disabled' ? 'link-arrow--disabled' : ''}}">{{item.action === 'disabled' ? '锁定' : '进入'}}</text>
      </view>
    </view>

    <view wx:if="{{profileMode === 'participant'}}" class="section-title">更多</view>
    <view wx:if="{{profileMode === 'participant'}}" class="link-list">
      <navigator
        wx:for="{{moreTools}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title">{{item.title}}</view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">打开</text>
      </navigator>
    </view>

    <view class="section-title">设置</view>
    <view class="link-list">
      <navigator
        wx:for="{{settings}}"
        wx:key="title"
        class="link-card"
        url="{{item.url}}"
        hover-class="link-card--active"
      >
        <view class="link-main">
          <view class="link-title-line">
            <text class="link-title">{{item.title}}</text>
            <text wx:if="{{item.badge}}" class="vis-badge vis-badge--{{item.badgeType}}">{{item.badge}}</text>
          </view>
          <view class="link-sub">{{item.sub}}</view>
        </view>
        <text class="link-arrow">进入</text>
      </navigator>
    </view>
  </view>
</view>
