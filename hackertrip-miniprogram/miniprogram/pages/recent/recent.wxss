}
.msg {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 28rpx 8rpx;
  border-bottom: 1rpx solid #efece3;
}
.mi {
  width: 84rpx;
  height: 84rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}
.mbody {
  flex: 1;
  min-width: 0;
}
.mt {
  font-size: 30rpx;
