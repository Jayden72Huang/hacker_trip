<view class="focus-page identity-edit-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">编辑身份</view>
    <view class="focus-subtitle">完善头像、昵称、角色、城市、技能和 GitHub，供身份卡和公开主页复用。</view>

    <view class="login-sync brutal-box {{isLoggedIn ? 'login-sync--done' : 'yellow-box'}}">
      <view>
        <view class="box-title">{{isLoggedIn ? '微信已登录' : '先用微信登录同步资料'}}</view>
        <view class="box-copy">{{isLoggedIn ? '保存后会同步到当前微信账号。' : '登录后可自动带入微信昵称和头像，并绑定身份卡、赛程和公开主页。'}}</view>
      </view>
      <button class="native-btn login-sync-btn" bindtap="openLogin">{{isLoggedIn ? '已登录' : '微信登录'}}</button>
    </view>

    <view class="brutal-box edit-head">
      <button class="avatar avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
        <text wx:else>头像</text>
      </button>
      <view class="edit-copy">
        <view class="box-title">{{form.nickname || '未填写昵称'}}</view>
        <view wx:if="{{form.role || form.city}}" class="box-copy">{{form.role}}{{form.role && form.city ? ' · ' : ''}}{{form.city}}</view>
      </view>
    </view>

    <view class="form-list">
      <view class="form-field">
        <text class="form-label">昵称</text>
        <input class="input-box" type="nickname" value="{{form.nickname}}" data-field="nickname" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">角色</text>
        <input class="input-box" value="{{form.role}}" data-field="role" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">城市</text>
        <input class="input-box" value="{{form.city}}" data-field="city" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">个人简介</text>
        <textarea class="textarea-box vault-textarea vault-textarea--compact" value="{{form.bio}}" data-field="bio" placeholder="用于身份页和报名表自我介绍" placeholder-class="placeholder-text" show-confirm-bar="{{false}}" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">技能</text>
        <input class="input-box" value="{{form.skills}}" data-field="skills" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">GitHub</text>
        <input class="input-box" value="{{form.github}}" data-field="github" bindinput="onFieldInput" />
      </view>
      <view class="form-section-title">报名资料库</view>
      <view class="form-field">
        <text class="form-label">当前想做的方向</text>
        <textarea class="textarea-box vault-textarea vault-textarea--compact" value="{{form.projectIdea}}" data-field="projectIdea" placeholder="例如：想做一个 AI Agent 工具，帮助创作者自动整理选题。" placeholder-class="placeholder-text" show-confirm-bar="{{false}}" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">想找的队友</text>
        <input class="input-box" value="{{form.lookingFor}}" data-field="lookingFor" placeholder="后端, 设计, 硬件, 增长" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">可投入时间</text>
        <input class="input-box" value="{{form.availability}}" data-field="availability" placeholder="全程 / 周末 / 线上支持" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">项目经历（一行一个）</text>
        <textarea class="textarea-box vault-textarea vault-textarea--multi" value="{{form.projectsText}}" data-field="projectsText" placeholder="{{projectsPlaceholder}}" placeholder-class="placeholder-text" show-confirm-bar="{{false}}" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">过往经历（一行一个）</text>
        <textarea class="textarea-box vault-textarea vault-textarea--multi" value="{{form.experiencesText}}" data-field="experiencesText" placeholder="{{experiencesPlaceholder}}" placeholder-class="placeholder-text" show-confirm-bar="{{false}}" bindinput="onFieldInput" />
      </view>
      <view class="form-field">
        <text class="form-label">获奖记录（一行一个）</text>
        <textarea class="textarea-box vault-textarea vault-textarea--multi" value="{{form.awardsText}}" data-field="awardsText" placeholder="{{awardsPlaceholder}}" placeholder-class="placeholder-text" show-confirm-bar="{{false}}" bindinput="onFieldInput" />
      </view>
    </view>

    <button class="native-btn save-profile" disabled="{{saving}}" bindtap="saveProfile">{{saving ? '保存中...' : '保存身份信息'}}</button>
  </view>
  <auth-modal id="authModal" bind:login="onAuthLogin" />
</view>
