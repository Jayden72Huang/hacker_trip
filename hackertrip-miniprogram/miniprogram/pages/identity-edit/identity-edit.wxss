@import "../focus.wxss";

.edit-head {
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.login-sync {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.login-sync--done {
  background: #FFFFFF;
}

.login-sync-btn {
  flex: 0 0 156rpx;
  width: 156rpx;
  margin: 0;
  font-size: 23rpx;
}

/* 微信头像大小的正方形头像(防 button 默认撑满) */
.avatar-button {
  width: 120rpx !important;
  height: 120rpx;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
  overflow: hidden;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 20rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  line-height: 120rpx;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.edit-copy {
  flex: 1;
  min-width: 0;
}

.form-field {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.save-profile {
  margin-top: 10rpx;
}
