@import "../focus.wxss";

.edit-head {
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.avatar-button {
  padding: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.edit-copy {
  flex: 1;
  min-width: 0;
}

.form-field {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.save-profile {
  margin-top: 10rpx;
}
