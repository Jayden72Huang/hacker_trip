<view class="aurora" />
<view wx:if="{{loading}}" class="state">加载中…</view>
<view wx:elif="{{!item}}" class="state">未找到该黑客松 🛰️</view>

<view wx:else class="page fade-up">
  <view class="title">{{item.name}}</view>

  <view class="meta-row">
    <text wx:if="{{item.startDate}}" class="meta">📅 {{item.startDate}} ~ {{item.endDate}}</text>
    <text wx:if="{{item.location}}" class="meta">📍 {{item.location}}</text>
    <text class="meta accent">{{modeLabel[item.mode] || item.mode}}</text>
  </view>

  <view wx:if="{{item.prizePool}}" class="prize-banner glass">
    🏆 奖金池 · {{item.prizePool}}
  </view>

  <view wx:if="{{item.summary}}" class="block glass">
    <view class="block-title">简介</view>
    <view class="block-text">{{item.summary}}</view>
  </view>

  <view wx:if="{{item.theme}}" class="block glass">
    <view class="block-title">主题</view>
    <view class="block-text">{{item.theme}}</view>
  </view>

  <view wx:if="{{item.tracks.length}}" class="block glass">
    <view class="block-title">赛道</view>
    <view class="chips">
      <text wx:for="{{item.tracks}}" wx:key="*this" class="chip chip-accent">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{item.techStack.length}}" class="block glass">
    <view class="block-title">技术方向</view>
    <view class="chips">
      <text wx:for="{{item.techStack}}" wx:key="*this" class="chip">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{item.website}}" class="block glass link-block" bindtap="copyWebsite">
    <view class="block-title">官网</view>
    <view class="block-text link">{{item.website}}</view>
    <view class="copy-hint">点击复制链接 →</view>
  </view>

  <!-- 引导生成身份卡 -->
  <view class="cta-card glow" bindtap="goMakeCard">
    <text class="cta-emoji">🎴</text>
    <view class="cta-body">
      <view class="cta-title">生成你的选手身份卡</view>
      <view class="cta-desc">报名前先亮明身份，分享到群里找队友</view>
    </view>
    <text class="cta-arrow">→</text>
  </view>

  <view style="height: 180rpx;" />
</view>

<!-- 底部操作栏 -->
<view wx:if="{{item}}" class="actionbar glass-strong">
  <view class="act-bookmark {{bookmarked ? 'on' : ''}}" bindtap="toggleBookmark">
    {{bookmarked ? '★ 已收藏' : '☆ 收藏'}}
  </view>
  <button class="btn-primary act-main" bindtap="register" disabled="{{registered}}">
    {{registered ? '✓ 已加入报名清单' : '加入报名清单'}}
  </button>
</view>
