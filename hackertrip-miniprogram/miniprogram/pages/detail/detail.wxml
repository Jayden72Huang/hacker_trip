<view class="focus-page detail-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content" wx:if="{{item}}">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="detail-hero brutal-box blue-box">
      <image wx:if="{{item.coverUrl}}" class="detail-hero-bg" src="{{item.coverUrl}}" mode="aspectFill" />
      <view class="detail-hero-mask"></view>
      <view class="detail-hero-content">
        <view class="detail-status">{{item.status === 'ended' ? '已结束' : item.status === 'ongoing' ? '进行中' : '即将开始'}}</view>
        <view class="detail-title-row">
          <view class="detail-logo-shell">
            <image wx:if="{{item.logoUrl}}" class="detail-logo-img" src="{{item.logoUrl}}" mode="aspectFill" />
            <image wx:else class="detail-logo-img detail-logo-img--fallback" src="/images/logo-transparent.png" mode="aspectFit" />
          </view>
          <view class="focus-title detail-title">{{item.name}}</view>
        </view>
        <view class="detail-summary">{{item.summary}}</view>
      </view>
    </view>

    <!-- 赛事热度（F3）：选手端关注沉淀 → 主办方获客钩子 -->
    <view class="brutal-box heat-box">
      <block wx:if="{{heat.empty}}">
        <view class="heat-head">
          <view class="heat-num heat-num--new">🆕</view>
          <view class="heat-label">新赛事 · 抢先关注</view>
        </view>
        <view class="heat-sub">还没有人关注这场。收藏或报名，点亮它的热度，帮更多开发者发现 👇</view>
      </block>
      <block wx:else>
        <view class="heat-head">
          <view class="heat-num">🔥 {{heat.heat}}</view>
          <view class="heat-label">热度值</view>
        </view>
        <view class="heat-sub">{{heat.fans}} 位开发者已关注 · {{heat.registrations}} 人想参加 · {{heat.bookmarks}} 人收藏</view>
        <view class="heat-bar"><view class="heat-bar-fill" style="width: {{heat.pct}}%;"></view></view>
      </block>
      <view class="heat-actions">
        <button class="heat-btn heat-btn--call" open-type="share" hover-class="native-link--active">📣 为它打 call</button>
        <button class="heat-btn heat-btn--claim" bindtap="claimHackathon" hover-class="native-link--active">这是你的赛事？认领</button>
      </view>
    </view>

    <view class="brutal-box">
      <view class="box-title">赛事信息</view>
      <view class="meta-list detail-meta">
        <view wx:for="{{metaRows}}" wx:key="label" class="meta-row" data-copy="{{item.copyValue || ''}}" bindtap="onMetaRowTap">
          <text class="meta-label">{{item.label}}</text>
          <text class="meta-value">{{item.value}}{{item.copyValue ? ' 📋' : ''}}</text>
        </view>
      </view>
    </view>

    <view class="brutal-box">
      <view class="box-title">赛道</view>
      <view class="chip-row detail-chips">
        <text wx:for="{{item.tracks}}" wx:key="*this" class="focus-chip focus-chip--yellow">{{item}}</text>
      </view>
      <view class="box-title detail-stack-title">技术标签</view>
      <view class="chip-row detail-chips">
        <text wx:for="{{item.techStack}}" wx:key="*this" class="focus-chip">{{item}}</text>
      </view>
    </view>

    <view class="brutal-box yellow-box">
      <view class="box-title">问 AI 是否适合</view>
      <view class="box-copy">把赛事名称、日期、城市、赛道和技术栈带入 Haki，让它按你的项目方向判断适配度。</view>
      <button class="native-btn detail-ai-btn" bindtap="askAI">问AI是否适合</button>
    </view>

    <view class="brutal-box">
      <view class="box-title">找队友 · 现场组队</view>
      <view class="box-copy">到场后签到，查看同场开放组队的伙伴，AI 帮你破冰。</view>
      <button class="native-btn detail-ai-btn" bindtap="goEventCheckin">进入现场组队</button>
    </view>

  </view>

  <view wx:elif="{{notFound}}" class="focus-content">
    <view class="brutal-box">
      <view class="box-title">赛事不存在或已下线</view>
      <view class="box-copy">这场赛事暂时不可访问，可以回到发现页查看正在开放的黑客松。</view>
      <navigator class="native-link native-link--yellow detail-empty-link" url="/pages/discover/discover" open-type="switchTab">去发现页</navigator>
    </view>
  </view>

  <view wx:if="{{item}}" class="fixed-actions">
    <button class="native-link" hover-class="native-link--active" bindtap="toggleBookmark">
      {{bookmarked ? '取消收藏' : '收藏赛事'}}
    </button>
    <button
      wx:if="{{item}}"
      class="native-link native-link--yellow"
      hover-class="native-link--active"
      bindtap="handleRegistrationCta"
    >{{item.registrationCtaText}}</button>
    <button class="native-link" open-type="share" hover-class="native-link--active">转发好友</button>
    <button class="native-btn" bindtap="joinSchedule">加入我的赛程</button>
  </view>

  <view wx:if="{{registrationQrVisible}}" class="registration-qr-mask" bindtap="closeRegistrationQr">
    <view class="registration-qr-panel" catchtap="stopPropagation">
      <view class="registration-qr-head">
        <view>
          <view class="registration-qr-kicker">WECHAT SIGNUP</view>
          <view class="registration-qr-title">扫码加入报名群</view>
        </view>
        <button class="registration-qr-close" bindtap="closeRegistrationQr">×</button>
      </view>
      <view class="registration-qr-image-shell">
        <image
          class="registration-qr-image"
          src="{{item.registrationLink.value}}"
          mode="widthFix"
          show-menu-by-longpress="{{true}}"
        />
      </view>
      <view class="registration-qr-tip">长按二维码识别或保存到相册</view>
      <view class="registration-qr-expiry">二维码注明 7 月 26 日前有效</view>
    </view>
  </view>
  <auth-modal id="authModal" />
</view>
