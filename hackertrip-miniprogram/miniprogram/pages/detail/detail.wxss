@import "../focus.wxss";

.detail-hero {
  margin-top: 6rpx;
}

.detail-status {
  display: inline-flex;
  padding: 8rpx 18rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
}

.detail-title {
  margin-top: 24rpx;
  color: #FFFFFF;
}

.detail-summary {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.detail-meta {
  margin-top: 24rpx;
}

.detail-chips {
  margin-top: 22rpx;
}

.detail-stack-title {
  margin-top: 30rpx;
}

.detail-ai-btn {
  margin-top: 24rpx;
}
