@import "../focus.wxss";

.detail-hero {
  position: relative;
  margin-top: 6rpx;
  min-height: 380rpx;
  overflow: hidden;
  background: #0C51ED;
}

.detail-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.28;
}

.detail-hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(12, 81, 237, 0.76), rgba(0, 0, 0, 0.78));
}

.detail-hero-content {
  position: relative;
  z-index: 1;
}

.detail-status {
  display: inline-flex;
  padding: 8rpx 18rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
}

.detail-title {
  flex: 1;
  min-width: 0;
  margin-top: 0;
  color: #FFFFFF;
  font-size: 48rpx;
  line-height: 1.18;
}

.detail-title-row {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  margin-top: 24rpx;
}

.detail-logo-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 7rpx 7rpx 0 0 #000000;
}

.detail-logo-img {
  width: 100%;
  height: 100%;
}

.detail-logo-img--fallback {
  width: 92rpx;
  height: 92rpx;
}

.detail-summary {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.detail-meta {
  margin-top: 24rpx;
}

.detail-chips {
  margin-top: 22rpx;
}

.detail-stack-title {
  margin-top: 30rpx;
}

.detail-ai-btn {
  margin-top: 24rpx;
}

/* 赛事热度看板（F3） */
.heat-box { background: #FFFFFF; }
.heat-head { display: flex; align-items: baseline; gap: 14rpx; }
.heat-num { font-size: 52rpx; font-weight: 900; color: #FF4D2E; line-height: 1; }
.heat-label { font-size: 24rpx; font-weight: 700; color: #7A7A75; }
.heat-sub { margin-top: 12rpx; font-size: 24rpx; font-weight: 700; color: #3D3D3D; line-height: 1.5; }
.heat-bar { margin: 16rpx 0 20rpx; height: 18rpx; background: #ECE8DB; border: 2rpx solid #000000; border-radius: 999rpx; overflow: hidden; }
.heat-bar-fill { height: 100%; background: linear-gradient(90deg, #FBD902, #FF4D2E); border-right: 2rpx solid #000000; transition: width .4s; }
.heat-actions { display: flex; gap: 16rpx; }
.heat-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  font-size: 26rpx; font-weight: 800;
  border: 3rpx solid #000000; border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}
.heat-btn--call { color: #FFFFFF; background: #0C51ED; }
.heat-btn--claim { color: #000000; background: #FBD902; }
.heat-btn:active { transform: translate(2rpx, 2rpx); box-shadow: 2rpx 2rpx 0 0 #000000; }

/* 热度 0 态（新赛事） */
.heat-num--new { font-size: 44rpx; color: #0C51ED; }
