@import "../focus.wxss";

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.setting-row--stack {
  align-items: stretch;
  flex-direction: column;
}

.toggle-list {
  margin-top: 20rpx;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-top: 3rpx solid #000000;
}

.toggle-row:first-child {
  border-top: none;
  padding-top: 4rpx;
}

.toggle-info {
  flex: 1;
  min-width: 0;
}

.toggle-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
  line-height: 1.3;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #555555;
  line-height: 1.35;
}

.ht-switch {
  flex-shrink: 0;
  transform: scale(0.9);
}

.setting-line {
  padding-right: 32rpx;
}

.logout-btn {
  margin-top: 36rpx;
}
