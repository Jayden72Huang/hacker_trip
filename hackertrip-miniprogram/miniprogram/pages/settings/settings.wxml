<view class="focus-page settings-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view wx:if="{{aiBanner}}" class="ai-note">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="focus-title">设置</view>
    <view class="focus-subtitle">管理账号、通知、隐私和缓存。</view>

    <view class="brutal-box blue-box" bindtap="goProfileLogin">
      <view class="box-title">{{account.name}}</view>
      <view class="box-copy">{{account.login}}</view>
      <view wx:if="{{account.sync}}" class="box-copy">{{account.sync}}</view>
    </view>

    <view class="list-card setting-row setting-row--stack">
      <view>
        <view class="list-title">通知提醒</view>
        <view class="list-subtitle">订阅后，HackerTrip 可在你授权的次数内发送上新、智能推荐和截止提醒。</view>
      </view>
      <view class="subscription-actions">
        <button class="subscription-btn subscription-btn--blue" bindtap="subscribeNewHackathons">上新提醒</button>
        <button class="subscription-btn" bindtap="subscribeSmartRecommendation">智能推荐</button>
        <button class="subscription-btn" bindtap="subscribeDeadlineReminder">截止提醒</button>
      </view>
    </view>

    <view wx:for="{{rows}}" wx:key="label" class="list-card setting-line" data-label="{{item.label}}" bindtap="onRowTap">
      <view class="list-title">{{item.label}}</view>
      <view class="list-subtitle">{{item.value}}</view>
    </view>

    <button wx:if="{{loggedIn}}" class="native-btn native-btn--danger logout-btn" bindtap="logout">退出登录</button>
    <button wx:else class="native-btn logout-btn" bindtap="goProfileLogin">去我的页登录</button>
  </view>
</view>
