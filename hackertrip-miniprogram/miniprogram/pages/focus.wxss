.focus-page {
  min-height: 100vh;
  padding: 0 32rpx 156rpx;
  background: #F4F1E8;
}

.focus-content {
  padding-top: 24rpx;
}

.focus-title {
  margin: 24rpx 0 14rpx;
  color: #000000;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
  letter-spacing: 0;
}

.focus-subtitle {
  margin-bottom: 26rpx;
  color: #3D3D3D;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.45;
}

.ai-note {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  margin: 12rpx 0 24rpx;
  color: #000000;
  background: #FBD902;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.brutal-box {
  padding: 28rpx;
  margin-bottom: 28rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.blue-box {
  color: #FFFFFF;
  background: #0C51ED;
}

.yellow-box {
  background: #FBD902;
}

.box-title {
  color: inherit;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.box-copy {
  margin-top: 12rpx;
  color: inherit;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.55;
}

.section-head {
  margin: 36rpx 0 18rpx;
  color: #000000;
  font-size: 34rpx;
  font-weight: 900;
}

.meta-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meta-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #000000;
}

.meta-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.meta-label {
  flex: 0 0 140rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
}

.meta-value {
  flex: 1;
  min-width: 0;
  color: #3D3D3D;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.focus-chip {
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 8rpx 18rpx;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.focus-chip--yellow {
  background: #FBD902;
}

.focus-chip--blue {
  color: #FFFFFF;
  background: #0C51ED;
}

.native-btn,
.native-link {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 26rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.native-btn--yellow,
.native-link--yellow {
  color: #000000;
  background: #FBD902;
}

.native-btn--white,
.native-link--white {
  color: #000000;
  background: #FFFFFF;
}

.native-btn--danger {
  color: #FFFFFF;
  background: #FF4D2E;
}

.native-btn:active,
.native-link:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.input-box {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 28rpx;
  font-weight: 800;
}

.textarea-box {
  min-height: 150rpx;
  padding-top: 22rpx;
}

.placeholder-text {
  color: #7A7A75;
}

.fixed-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 70;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 4rpx solid #000000;
  box-shadow: 0 -6rpx 0 0 #000000;
}

.fixed-actions .native-btn,
.fixed-actions .native-link {
  flex: 1;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 24rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
  font-size: 48rpx;
  font-weight: 900;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.stat-item {
  padding: 18rpx 12rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.list-card {
  display: block;
  padding: 26rpx;
  margin-bottom: 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.list-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.list-subtitle {
  margin-top: 10rpx;
  color: #3D3D3D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}
