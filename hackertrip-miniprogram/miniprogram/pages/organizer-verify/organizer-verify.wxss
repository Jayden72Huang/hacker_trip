@import "../focus.wxss";

.verify-title {
  color: #FFFFFF;
}

.verify-sub {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.5;
}

.form-field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #000000;
  font-size: 24rpx;
  font-weight: 900;
}

.input-box,
.picker-box {
  width: 100%;
  box-sizing: border-box;
  min-height: 86rpx;
  padding: 22rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.verify-action {
  margin-top: 28rpx;
}
