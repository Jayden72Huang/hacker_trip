<view class="focus-page my-works-page">
  <navbar title="{{title}}" showBack="{{true}}" showHome="{{true}}" />
  <view class="focus-content">
    <view class="focus-title">我的作品</view>
    <view class="focus-subtitle">手动添加或审核 CLI 提交的作品，决定哪些展示到公开主页。</view>

    <button class="native-btn work-add-btn" bindtap="openCreateForm">＋ 添加作品</button>

    <!-- 手动添加 / 编辑表单 -->
    <view wx:if="{{formOpen}}" class="brutal-box work-form">
      <view class="box-title">{{editingId ? '编辑作品' : '添加作品'}}</view>
      <view class="work-form-field">
        <view class="work-form-label">产品 Logo / 封面图</view>
        <view class="work-form-cover-row">
          <image wx:if="{{form.cover}}" class="work-form-cover" src="{{form.cover}}" mode="aspectFill" bindtap="chooseCover" />
          <view wx:else class="work-form-cover work-form-cover--empty" bindtap="chooseCover">＋ 选图</view>
          <view class="work-form-cover-actions">
            <view class="work-form-cover-hint">建议方形 Logo 或产品截图，会展示在作品卡和公开主页</view>
            <view wx:if="{{form.cover}}" class="work-form-cover-remove" bindtap="removeCover">移除图片</view>
          </view>
        </view>
      </view>
      <view class="work-form-field">
        <view class="work-form-label">作品名称 *</view>
        <input class="work-form-input" value="{{form.name}}" data-field="name" bindinput="onFormInput" maxlength="60" placeholder="例如：HackerTrip 小程序" />
      </view>
      <view class="work-form-field">
        <view class="work-form-label">一句话简介</view>
        <textarea class="work-form-input work-form-textarea" value="{{form.summary}}" data-field="summary" bindinput="onFormInput" maxlength="200" placeholder="它解决什么问题、用了什么技术" />
      </view>
      <view class="work-form-field">
        <view class="work-form-label">获奖情况</view>
        <input class="work-form-input" value="{{form.awards}}" data-field="awards" bindinput="onFormInput" maxlength="80" placeholder="例如：AdventureX 2026 一等奖" />
      </view>
      <view class="work-form-field">
        <view class="work-form-label">代码仓库链接</view>
        <input class="work-form-input" value="{{form.repo}}" data-field="repo" bindinput="onFormInput" maxlength="300" placeholder="https://github.com/..." />
      </view>
      <view class="work-form-field">
        <view class="work-form-label">Demo 链接</view>
        <input class="work-form-input" value="{{form.demo}}" data-field="demo" bindinput="onFormInput" maxlength="300" placeholder="https://..." />
      </view>
      <view class="work-form-field">
        <view class="work-form-label">技术栈（用顿号或空格分隔）</view>
        <input class="work-form-input" value="{{form.techText}}" data-field="techText" bindinput="onFormInput" maxlength="200" placeholder="例如：React、Node.js、CloudBase" />
      </view>
      <view class="work-form-actions">
        <button class="native-btn work-action" bindtap="closeForm">取消</button>
        <button class="native-btn native-btn--yellow work-action" bindtap="submitForm">{{saving ? '保存中…' : (editingId ? '保存修改' : '添加作品')}}</button>
      </view>
    </view>

    <view wx:if="{{loading}}" class="list-card">
      <view class="list-title">正在加载</view>
      <view class="list-subtitle">读取你的作品列表...</view>
    </view>

    <view wx:elif="{{error}}" class="brutal-box yellow-box">
      <view class="box-title">需要处理</view>
      <view class="box-copy">{{error}}</view>
    </view>

    <view wx:elif="{{!works.length}}" class="list-card">
      <view class="list-title">暂无作品</view>
      <view class="list-subtitle">点上方「＋ 添加作品」手动录入，或在电脑端用 CLI 提交，都会出现在这里等待发布。</view>
    </view>

    <view wx:for="{{works}}" wx:key="_id" class="list-card work-card">
      <image wx:if="{{item.cover}}" class="work-cover" src="{{item.cover}}" mode="aspectFill" />
      <view wx:else class="work-cover work-cover--empty">WORK</view>
      <view class="work-body">
        <view class="work-head">
          <view class="list-title work-title">{{item.name}}</view>
          <view class="status-badge {{item.statusClass}}">{{item.statusText}}</view>
        </view>
        <view wx:if="{{item.summary}}" class="list-subtitle">{{item.summary}}</view>
        <view wx:if="{{item.awards}}" class="work-awards">获奖：{{item.awards}}</view>
        <view wx:if="{{item.repo || item.demo}}" class="work-links">
          <text wx:if="{{item.repo}}">Repo 已提交</text>
          <text wx:if="{{item.demo}}">Demo 已提交</text>
        </view>
        <view wx:if="{{item.techStack.length}}" class="chip-row work-tags">
          <text wx:for="{{item.techStack}}" wx:key="*this" class="focus-chip">{{item}}</text>
        </view>
        <view class="work-actions">
          <button
            class="native-btn work-action {{item.status === 'published' ? 'native-btn--yellow' : ''}}"
            data-id="{{item._id}}"
            data-action="{{item.primaryAction}}"
            bindtap="runAction"
          >{{item.primaryActionText}}</button>
          <button
            class="native-btn work-action"
            data-id="{{item._id}}"
            bindtap="openEditForm"
          >编辑</button>
          <button
            class="native-btn native-btn--danger work-action"
            data-id="{{item._id}}"
            data-action="delete"
            bindtap="runAction"
          >删除</button>
        </view>
      </view>
    </view>
  </view>
  <auth-modal id="authModal" bind:login="onAuthLogin" />
</view>
