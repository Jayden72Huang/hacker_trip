@import "../focus.wxss";

.work-card {
  display: flex;
  gap: 20rpx;
}

.work-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 148rpx;
  width: 148rpx;
  height: 148rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 24rpx;
  font-weight: 900;
  overflow: hidden;
}

.work-cover--empty {
  color: #000000;
  background: #FBD902;
}

.work-body {
  flex: 1;
  min-width: 0;
}

.work-head {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.work-title {
  flex: 1;
  min-width: 0;
}

.status-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  color: #FFFFFF;
  background: #000000;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.1;
}

.status-pending {
  color: #000000;
  background: #FBD902;
}

.status-published {
  color: #FFFFFF;
  background: #0C51ED;
}

.status-rejected {
  color: #FFFFFF;
  background: #FF4D2E;
}

.work-awards,
.work-links {
  margin-top: 12rpx;
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.35;
}

.work-links {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #3D3D3D;
}

.work-tags {
  margin-top: 16rpx;
}

.work-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.work-action {
  min-height: 70rpx;
  margin: 0;
  padding: 0 12rpx;
  font-size: 23rpx;
}
