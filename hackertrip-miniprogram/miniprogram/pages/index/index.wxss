.discovery-page {
  padding-bottom: 210rpx;
}

.hero {
  position: relative;
  display: flex;
  min-height: 278rpx;
  padding: 30rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 10rpx 10rpx 0 0 #000000;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 70%;
}

.city-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 14rpx;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.city-label,
.city-name {
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.city-name {
  color: #0C51ED;
}

.hero .page-title {
  margin-top: 26rpx;
  margin-bottom: 12rpx;
}

.city-sketch {
  position: absolute;
  right: -18rpx;
  top: 28rpx;
  width: 236rpx;
  height: 214rpx;
  opacity: 0.95;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 88rpx;
  padding: 0 22rpx;
  margin-top: 34rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 28rpx;
  font-weight: 800;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
}

.filter-chip {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto !important;
  width: auto !important;
  min-height: 60rpx;
  padding: 0 24rpx;
  margin: 0;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.filter-chip::after {
  border: none;
}

.filter-chip--active {
  background: #FBD902;
}

.focus-card {
  padding: 30rpx;
  color: #FFFFFF;
  background: #0C51ED;
  border: 4rpx solid #000000;
  border-radius: 18rpx;
  box-shadow: 10rpx 10rpx 0 0 #000000;
}

.focus-kicker {
  display: inline-flex;
  padding: 8rpx 14rpx;
  color: #000000;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.focus-title {
  margin-top: 20rpx;
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.focus-meta {
  margin-top: 10rpx;
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.focus-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 24rpx;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 5rpx 5rpx 0 0 #000000;
  font-size: 26rpx;
  font-weight: 900;
}

.focus-cta--active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.featured-scroll {
  width: 100%;
  white-space: nowrap;
}

.featured-card {
  display: inline-flex;
  flex-direction: column;
  width: 292rpx;
  min-height: 242rpx;
  padding: 24rpx;
  margin-right: 22rpx;
  vertical-align: top;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.featured-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.featured-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: normal;
}

.featured-subtitle {
  margin-top: 12rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: normal;
}

.featured-prize {
  margin-top: 16rpx;
  color: #0C51ED;
  font-size: 24rpx;
  font-weight: 900;
}

.featured-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.mini-tag {
  padding: 6rpx 10rpx;
  color: #000000;
  background: #FBD902;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.list-count {
  margin-top: 36rpx;
  color: #7A7A75;
  font-size: 24rpx;
  font-weight: 900;
}
