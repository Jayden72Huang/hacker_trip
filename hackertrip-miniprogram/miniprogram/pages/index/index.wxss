.discovery-page {
  padding-right: 24rpx;
  padding-bottom: 190rpx;
  padding-left: 24rpx;
}

.discovery-page .content {
  padding-top: 16rpx;
}

.discovery-page .section-title {
  margin: 28rpx 0 14rpx;
  font-size: 32rpx;
}

.hero {
  position: relative;
  display: flex;
  align-items: flex-start;
  min-height: 164rpx;
  padding: 16rpx 0 24rpx;
  overflow: hidden;
  background: transparent;
}

.hero-brand {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  margin-top: 0;
}

.hero-logo {
  flex-shrink: 0;
  width: 132rpx;
  height: 132rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.city-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 14rpx;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.city-label,
.city-name {
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.city-name {
  color: #0C51ED;
}

.city-caret {
  color: #000000;
  font-size: 20rpx;
  font-weight: 900;
}

.hero .page-title {
  margin: 0 0 8rpx;
  font-size: 66rpx;
  line-height: 1.12;
  text-shadow:
    4rpx 4rpx 0 #FBD902,
    8rpx 8rpx 0 rgba(12, 81, 237, 0.24);
}

.hero .page-subtitle {
  margin-bottom: 0;
  overflow: visible;
  white-space: nowrap;
  color: #3D3D3D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  text-shadow:
    2rpx 2rpx 0 #FFFFFF,
    4rpx 4rpx 0 rgba(12, 81, 237, 0.18);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: flex-start;
  width: 100%;
  margin-top: 12rpx;
  margin-bottom: 28rpx;
}

.search-city {
  height: 76rpx;
  flex: 0 0 auto;
  padding: 0 16rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 26rpx;
  font-weight: 800;
}

.search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 42rpx !important;
  height: 42rpx;
  padding: 0;
  margin: 0;
  color: #FFFFFF;
  background: #000000;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.search-clear::after {
  border: none;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-chip {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto !important;
  width: auto !important;
  min-height: 52rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 3rpx 3rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

.filter-chip::after {
  border: none;
}

.filter-chip--active {
  background: #FBD902;
}

.featured-scroll {
  width: 100%;
  white-space: nowrap;
}

.featured-card {
  display: inline-flex;
  flex-direction: column;
  width: 292rpx;
  min-height: 242rpx;
  padding: 24rpx;
  margin-right: 22rpx;
  vertical-align: top;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.featured-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.featured-title {
  color: #000000;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: normal;
}

.featured-subtitle {
  margin-top: 12rpx;
  color: #3D3D3D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: normal;
}

.featured-prize {
  margin-top: 16rpx;
  color: #0C51ED;
  font-size: 24rpx;
  font-weight: 900;
}

.featured-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.mini-tag {
  padding: 6rpx 10rpx;
  color: #000000;
  background: #FBD902;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.list-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-top: 10rpx;
}

.more-btn {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  width: auto !important;
  height: 52rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 3rpx 3rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.more-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.city-picker {
  padding: 32rpx 32rpx calc(172rpx + env(safe-area-inset-bottom));
  background: #F4F1E8;
  border-top: 4rpx solid #000000;
}

.city-picker-title {
  margin-bottom: 24rpx;
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
}

.city-picker-list {
  max-height: 560rpx;
  padding-bottom: 12rpx;
}

.city-picker-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 28rpx;
  font-weight: 900;
}

.city-picker-item.on {
  color: #FFFFFF;
  background: #0C51ED;
}
