.discovery-page {
  padding-right: 24rpx;
  padding-bottom: 190rpx;
  padding-left: 24rpx;
}

.discovery-page .content {
  padding-top: 16rpx;
}

.discovery-page .section-title {
  margin: 28rpx 0 14rpx;
  font-size: 32rpx;
}

.hero {
  position: relative;
  display: flex;
  align-items: flex-start;
  min-height: 164rpx;
  padding: 16rpx 0 24rpx;
  overflow: hidden;
  background: transparent;
}

.hero-brand {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  margin-top: 0;
}

.hero-logo {
  flex-shrink: 0;
  width: 132rpx;
  height: 132rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.city-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 14rpx;
  background: #FBD902;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.city-label,
.city-name {
  color: #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.city-name {
  color: #0C51ED;
}

.city-caret {
  color: #000000;
  font-size: 20rpx;
  font-weight: 900;
}

.hero .page-title {
  margin: 0 0 8rpx;
  font-size: 66rpx;
  line-height: 1.12;
  text-shadow:
    4rpx 4rpx 0 #FBD902,
    8rpx 8rpx 0 rgba(12, 81, 237, 0.24);
}

.hero .page-subtitle {
  margin-bottom: 0;
  overflow: visible;
  white-space: nowrap;
  color: #3D3D3D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  text-shadow:
    2rpx 2rpx 0 #FFFFFF,
    4rpx 4rpx 0 rgba(12, 81, 237, 0.18);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: flex-start;
  width: 100%;
  margin-top: 12rpx;
  margin-bottom: 28rpx;
}

.search-city {
  height: 76rpx;
  flex: 0 0 auto;
  padding: 0 16rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.sort-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex: 0 0 auto;
  height: 76rpx;
  padding: 0 16rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
}

.sort-caret {
  color: #0C51ED;
  font-size: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 26rpx;
  font-weight: 800;
}

.search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 42rpx !important;
  height: 42rpx;
  padding: 0;
  margin: 0;
  color: #FFFFFF;
  background: #000000;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.search-clear::after {
  border: none;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
}

.filter-chip {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto !important;
  width: auto !important;
  min-height: 52rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #000000;
  background: #FFFFFF;
  border: 3rpx solid #000000;
  border-radius: 999rpx;
  box-shadow: 3rpx 3rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
}

.filter-chip::after {
  border: none;
}

.filter-chip--active {
  background: #FBD902;
}

.featured-scroll {
  width: 100%;
  white-space: nowrap;
}

.featured-switch {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  width: 100%;
  margin: 18rpx 0 12rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 14rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
}

.featured-switch::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 4rpx;
  background: #000000;
  content: '';
  transform: translateX(-2rpx);
  z-index: 2;
}

.featured-switch-item {
  position: relative;
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  height: 60rpx;
  padding: 0;
  margin: 0;
  color: #000000;
  background: transparent;
  border: none;
  border-radius: 0;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
  z-index: 1;
}

.featured-switch-item::after {
  border: none;
}

.featured-switch-item--active {
  color: #FFFFFF;
  background: #0C51ED;
}

.featured-head-line {
  width: 100%;
  height: 5rpx;
  margin-bottom: 16rpx;
  background: #000000;
  box-shadow: 0 8rpx 0 0 #FBD902;
}

.recommendation-hint {
  margin: 0 0 12rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.4;
}

.recommendation-guide {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx dashed #000000;
  border-radius: 16rpx;
}

.recommendation-guide-copy {
  flex: 1;
  min-width: 0;
}

.recommendation-guide-title {
  color: #000000;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.recommendation-guide-text {
  margin-top: 6rpx;
  color: #3D3D3D;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

.recommendation-guide-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 0 0 auto;
}

.recommendation-guide-btn {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  width: auto !important;
  min-width: 138rpx;
  height: 56rpx;
  padding: 0 16rpx;
  margin: 0;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 0 0 #000000;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
}

.recommendation-guide-btn::after {
  border: none;
}

.recommendation-guide-btn--ghost {
  color: #000000;
  background: #FFFFFF;
}

.recommendation-empty {
  padding: 24rpx 18rpx;
  margin-bottom: 8rpx;
  color: #3D3D3D;
  background: #FFFFFF;
  border: 4rpx dashed #000000;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.featured-card {
  display: inline-flex;
  flex-direction: column;
  width: 304rpx;
  min-height: 0;
  padding: 18rpx 18rpx 16rpx;
  margin-right: 18rpx;
  vertical-align: top;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 0 0 #000000;
}

.featured-card--active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.featured-title {
  color: #000000;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: normal;
}

.featured-reason {
  display: inline-flex;
  align-self: flex-start;
  max-width: 100%;
  margin-top: 8rpx;
  padding: 4rpx 8rpx;
  overflow: hidden;
  color: #0C51ED;
  background: #FBD902;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 12rpx;
}

.featured-info-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  min-width: 0;
}

.featured-info-row--split {
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.featured-inline {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.featured-inline--prize {
  flex: 1;
}

.featured-info-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 52rpx;
  min-height: 28rpx;
  padding: 0 6rpx;
  color: #000000;
  background: #ECE8DB;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.2;
}

.featured-info-value {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.35;
  white-space: normal;
}

.featured-info-value--location {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-mode-pill {
  display: inline-flex;
  align-items: center;
  min-height: 28rpx;
  padding: 0 10rpx;
  color: #FFFFFF;
  background: #000000;
  border: 2rpx solid #000000;
  border-radius: 8rpx;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.2;
}

.featured-prize {
  display: block;
  overflow: hidden;
  color: #0C51ED;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 26rpx 0 16rpx;
}

.list-head-title {
  flex-shrink: 0;
  margin: 0 !important;
}

.list-head-line {
  flex: 1;
  min-width: 72rpx;
  height: 5rpx;
  background: #000000;
  box-shadow: 0 8rpx 0 0 #FBD902;
}

.more-btn {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  width: auto !important;
  height: 52rpx;
  padding: 0 22rpx;
  margin: 0;
  color: #FFFFFF;
  background: #0C51ED;
  border: 3rpx solid #000000;
  border-radius: 12rpx;
  box-shadow: 3rpx 3rpx 0 0 #000000;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.more-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 0 #000000;
}

.city-picker {
  padding: 32rpx 32rpx calc(172rpx + env(safe-area-inset-bottom));
  background: #F4F1E8;
  border-top: 4rpx solid #000000;
}

.city-picker-title {
  margin-bottom: 24rpx;
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
}

.city-picker-list {
  max-height: 560rpx;
  padding-bottom: 12rpx;
}

.city-picker-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 28rpx;
  font-weight: 900;
}

.city-picker-item.on {
  color: #FFFFFF;
  background: #0C51ED;
}

.sort-picker {
  padding: 32rpx 32rpx calc(96rpx + env(safe-area-inset-bottom));
  background: #F4F1E8;
  border-top: 4rpx solid #000000;
}

.sort-picker-title {
  margin-bottom: 24rpx;
  color: #000000;
  font-size: 32rpx;
  font-weight: 900;
}

.sort-picker-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
  color: #000000;
  background: #FFFFFF;
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 28rpx;
  font-weight: 900;
}

.sort-picker-item.on {
  color: #FFFFFF;
  background: #0C51ED;
}
