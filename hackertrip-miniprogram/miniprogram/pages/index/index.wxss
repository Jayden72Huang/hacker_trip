.cover-page {
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #000000;
}

.cover-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 100vh;
  padding-right: 40rpx;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
  padding-left: 40rpx;
  overflow: hidden;
  color: #FFFFFF;
  background: #000000;
}

.cover-hero-bg,
.cover-hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.cover-hero-bg {
  z-index: 0;
}

.cover-hero-overlay {
  z-index: 1;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.34) 42%, rgba(0, 0, 0, 0.78) 100%);
}

.cover-brand,
.cover-slogan,
.cover-actions {
  position: relative;
  z-index: 2;
}

.cover-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  align-self: flex-start;
  max-width: 560rpx;
}

.cover-logo {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
}

.cover-brand-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.cover-brand-name,
.cover-brand-sub {
  display: block;
  color: #FFFFFF;
  line-height: 1.05;
  text-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.52);
}

.cover-brand-name {
  font-size: 30rpx;
  font-weight: 900;
}

.cover-brand-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.cover-slogan {
  width: 100%;
  margin-top: auto;
  margin-bottom: auto;
  padding-top: 64rpx;
}

.cover-kicker,
.cover-title,
.cover-desc {
  display: block;
  color: #FFFFFF;
  text-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.58);
}

.cover-kicker {
  margin-bottom: 24rpx;
  color: #FBD902;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.cover-title {
  font-size: 78rpx;
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: 0;
}

.cover-title--second {
  margin-top: 8rpx;
}

.cover-desc {
  max-width: 100%;
  margin-top: 24rpx;
  overflow: visible;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
  white-space: nowrap;
}

.cover-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.cover-action {
  position: relative;
  display: flex !important;
  align-items: center;
  width: 100% !important;
  height: 88rpx;
  padding: 0 26rpx;
  margin: 0;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.32);
  border-bottom: 5rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 0;
  text-align: left;
}

.cover-action--primary {
  color: #000000;
  background: rgba(251, 217, 2, 0.94);
  border-bottom-color: #FFFFFF;
}

.cover-action-title {
  flex-shrink: 0;
  color: inherit;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.cover-action-meta {
  margin-left: 18rpx;
  color: inherit;
  font-size: 25rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1;
  opacity: 0.9;
}

.cover-action-arrow {
  margin-left: auto;
  color: inherit;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.cover-action:active {
  transform: translateY(3rpx);
  opacity: 0.88;
}
