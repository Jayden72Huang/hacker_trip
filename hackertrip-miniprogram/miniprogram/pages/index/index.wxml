<view class="cover-page">
  <view class="cover-hero" style="padding-top: {{heroTopPadding}}px;">
    <image class="cover-hero-bg" src="/images/home-brand-cover.jpg" mode="aspectFill" />
    <view class="cover-hero-overlay"></view>
    <view class="cover-brand">
      <image class="cover-logo" src="/images/logo-transparent.png" mode="aspectFit" />
      <view class="cover-brand-copy">
        <text class="cover-brand-name">HackerTrip</text>
        <text class="cover-brand-sub">你的一站式AI黑客松平台!</text>
      </view>
    </view>
    <view class="cover-slogan">
      <text class="cover-kicker">FIND · TEAM · BUILD</text>
      <text class="cover-title">把想法带上路</text>
      <text class="cover-title cover-title--second">去黑客松里见真章</text>
      <text class="cover-desc">发现赛事、找到队友、推广作品，从这里开始。</text>
    </view>
    <view class="cover-actions">
      <button class="cover-action cover-action--primary" bindtap="goJoinHackathon">
        <text class="cover-action-title">参加黑客松</text>
        <text class="cover-action-meta">JOIN</text>
        <text class="cover-action-arrow">→</text>
      </button>
      <button class="cover-action" bindtap="goHostHackathon">
        <text class="cover-action-title">举办黑客松</text>
        <text class="cover-action-meta">HOST</text>
        <text class="cover-action-arrow">→</text>
      </button>
    </view>
  </view>
</view>
