<view class="page page--tab discovery-page">
  <navbar title="{{title}}" showBack="{{false}}" showHome="{{false}}" />

  <view class="content">
    <view wx:if="{{aiBanner}}" class="ai-banner">
      <text>来自微信AI助手</text>
      <text>{{aiIntentText}}</text>
    </view>

    <view class="hero">
      <view class="hero-copy">
        <view class="city-row">
          <text class="city-label">当前城市</text>
          <text class="city-name">{{city}}</text>
        </view>
        <view class="page-title">发现黑客松</view>
        <view class="page-subtitle">按城市、赛道、时间和技术栈找到可报名赛事。</view>
      </view>
      <image class="city-sketch" src="/images/sketches/shenzhen-t.png" mode="aspectFit" />
    </view>

    <view class="search-box">
      <t-icon name="search" size="34rpx" color="#000000" />
      <input
        class="search-input"
        value="{{query}}"
        placeholder="搜索 AI、深圳、Web3、硬件"
        confirm-type="search"
        bindinput="onSearchInput"
      />
    </view>

    <view class="filter-row">
      <button
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{activeFilter === item.key ? 'filter-chip--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onFilterTap"
      >
        {{item.label}}
      </button>
    </view>

    <view wx:if="{{focusEvent}}" class="section-title">正在关注</view>
    <view wx:if="{{focusEvent}}" class="focus-card">
      <view class="focus-kicker">{{focusEvent.status === 'ongoing' ? '正在进行' : '即将开始'}}</view>
      <view class="focus-title">{{focusEvent.name}}</view>
      <view class="focus-meta">时间 {{focusEvent.startDate}} - {{focusEvent.endDate}}</view>
      <view class="focus-meta">地点 {{focusEvent.location}} · {{focusEvent.modeText}}</view>
      <view class="focus-meta">奖金 {{focusEvent.prizePool}}</view>
      <navigator class="focus-cta" url="/pages/detail/detail?id={{focusEvent.id}}" hover-class="focus-cta--active">
        查看赛事详情
      </navigator>
    </view>

    <view class="section-title">精选推荐</view>
    <scroll-view class="featured-scroll" scroll-x enable-flex>
      <navigator
        wx:for="{{featured}}"
        wx:key="id"
        class="featured-card"
        url="/pages/detail/detail?id={{item.id}}"
        hover-class="featured-card--active"
      >
        <view class="featured-title">{{item.shortName || item.name}}</view>
        <view class="featured-subtitle">{{item.startDate}} · {{item.city}} · {{item.modeText}}</view>
        <view class="featured-prize">{{item.prizePool}}</view>
        <view class="featured-tags">
          <text wx:for="{{item.techStack}}" wx:key="*this" wx:if="{{index < 3}}" class="mini-tag">{{item}}</text>
        </view>
      </navigator>
    </scroll-view>

    <view class="list-head">
      <view class="section-title">更多黑客松</view>
      <text class="list-count">{{hackathons.length}} / {{totalCount}}</text>
    </view>

    <hackathon-card
      wx:for="{{hackathons}}"
      wx:key="id"
      item="{{item}}"
      bookmarked="{{item.bookmarked}}"
      bind:bookmark="onBookmark"
    />
  </view>
</view>
