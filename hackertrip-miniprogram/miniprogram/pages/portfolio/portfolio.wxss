@import "../focus.wxss";

.project-card {
  display: flex;
  gap: 22rpx;
}

.illus {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 148rpx;
  width: 148rpx;
  height: 148rpx;
  color: #000000;
  background: linear-gradient(135deg, #FBD902 0%, #FBD902 45%, #0C51ED 45%, #0C51ED 100%);
  border: 4rpx solid #000000;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0 0 #000000;
  font-size: 27rpx;
  font-weight: 900;
}

.project-main {
  flex: 1;
  min-width: 0;
}

.project-meta {
  margin-top: 14rpx;
  color: #000000;
  font-size: 23rpx;
  font-weight: 900;
}

.project-tags {
  margin-top: 18rpx;
}
