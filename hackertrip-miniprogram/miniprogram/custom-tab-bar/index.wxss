.tabbar {
  /* 底部贴边全宽：符合微信 tab 习惯，不悬浮 */
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 490;
  display: flex;
  align-items: center;
  height: 104rpx;
  padding: 10rpx 16rpx calc(10rpx + env(safe-area-inset-bottom));
  box-sizing: content-box;
  background: #FFFFFF;
  border-top: 4rpx solid #000000;
}

.tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 76rpx;
  color: #7A7A75;
  border: 4rpx solid transparent;
  border-radius: 12rpx;
}

.tabbar__item--active {
  color: #FFFFFF;
  background: #0C51ED;
  border-color: #000000;
  box-shadow: 4rpx 4rpx 0 0 #000000;
}

.tabbar__text {
  font-size: 21rpx;
  line-height: 1;
  font-weight: 900;
}

.tabbar__glyph { font-size: 34rpx; line-height: 1; }
