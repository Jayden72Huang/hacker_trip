.tabbar {
  /* 底部贴边全宽：内容行压扁，下方留白是 iPhone 手势条安全区 */
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 490;
  display: flex;
  align-items: center;
  height: 84rpx;
  padding: 0 8rpx env(safe-area-inset-bottom);
  box-sizing: content-box;
  background: #FFFFFF;
  border-top: 4rpx solid #000000;
}

.tabbar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

/* 高亮块：内容自适应的紧凑矩形，不拉满整格 */
.tabbar__chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 4rpx 24rpx;
  color: #7A7A75;
  border: 3rpx solid transparent;
  border-radius: 10rpx;
}

.tabbar__chip--active {
  color: #FFFFFF;
  background: #0C51ED;
  border-color: #000000;
  box-shadow: 3rpx 3rpx 0 0 #000000;
}

.tabbar__text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  white-space: nowrap;
  flex-shrink: 0;
}

.tabbar__glyph { font-size: 32rpx; line-height: 32rpx; height: 32rpx; display: block; }
