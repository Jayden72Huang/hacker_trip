<view class="tabbar">
  <navigator
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tabbar__item {{selected === index ? 'tabbar__item--active' : ''}}"
    url="{{item.pagePath}}"
    open-type="switchTab"
    hover-class="none"
  >
    <view class="tabbar__chip {{selected === index ? 'tabbar__chip--active' : ''}}">
      <text class="tabbar__glyph" style="color: {{selected === index ? '#FFFFFF' : color}}; font-size: {{item.glyphSize}}rpx;">{{item.glyph}}</text>
      <text class="tabbar__text">{{item.text}}</text>
    </view>
  </navigator>
</view>
